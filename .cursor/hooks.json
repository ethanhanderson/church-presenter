{
  "version": 1,
  "hooks": {
    "afterFileEdit": [
      {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \".cursor/hooks/windows-app-org-edit-tracker.ps1\"",
        "matcher": "Write",
        "timeout": 10
      }
    ],
    "afterTabFileEdit": [
      {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \".cursor/hooks/windows-app-org-edit-tracker.ps1\"",
        "timeout": 10
      }
    ],
    "stop": [
      {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \".cursor/hooks/windows-app-org-stop.ps1\"",
        "timeout": 10,
        "loop_limit": 1
      }
    ]
  }
}
