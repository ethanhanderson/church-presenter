<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ChurchPresenter.Views.SettingsIntegrationsDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ChurchPresenter.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Padding="32,20,32,32">
        <Border x:Name="SettingsColumnRoot" VerticalAlignment="Stretch">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <local:SettingsDetailHeader
                    Grid.Row="0"
                    Margin="0,0,0,28"
                    CurrentSegmentText="Integrations" />

                <Border
                    x:Name="DetailContentRoot"
                    Grid.Row="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Top">
                    <StackPanel Spacing="16">
                        <Border
                            Padding="16"
                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <StackPanel Spacing="16">
                                <TextBlock FontWeight="SemiBold" Text="Music Manager" />
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Supabase URL" />
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="Project URL used for Sunday Manager music queries."
                                        TextWrapping="Wrap" />
                                    <TextBox
                                        MinWidth="320"
                                        HorizontalAlignment="Left"
                                        PlaceholderText="https://your-project.supabase.co"
                                        Text="{x:Bind ViewModel.MusicSupabaseUrl, Mode=TwoWay}" />
                                </StackPanel>
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Publishable key" />
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="API key used for read-only Sunday Manager access."
                                        TextWrapping="Wrap" />
                                    <TextBox
                                        MinWidth="320"
                                        HorizontalAlignment="Left"
                                        Text="{x:Bind ViewModel.MusicPublishableKey, Mode=TwoWay}" />
                                </StackPanel>
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Default song action" />
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="Preferred action when working with Music Manager songs."
                                        TextWrapping="Wrap" />
                                    <ComboBox
                                        MinWidth="260"
                                        HorizontalAlignment="Left"
                                        ItemsSource="{x:Bind ViewModel.MusicSongActionChoices, Mode=OneWay}"
                                        SelectedItem="{x:Bind ViewModel.MusicDefaultSongAction, Mode=TwoWay}" />
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <ToggleSwitch Header="Prefer set import view" IsOn="{x:Bind ViewModel.MusicPreferSetImportView, Mode=TwoWay}" />
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="Open set import view first when available."
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
