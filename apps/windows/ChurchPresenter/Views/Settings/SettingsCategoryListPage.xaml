<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ChurchPresenter.Views.SettingsCategoryListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">


    <Grid Padding="32,20,32,40">
        <Border
            x:Name="ContentRoot"
            VerticalAlignment="Top">
            <StackPanel Spacing="28">
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Settings" />

                <StackPanel Spacing="10">
                    <TextBlock
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="Presentation" />
                    <Button Click="Output_Click" Style="{StaticResource SettingsNavCardStyle}">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <FontIcon
                                Grid.Column="0"
                                Width="28"
                                Margin="0,0,14,0"
                                VerticalAlignment="Center"
                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                FontSize="20"
                                Glyph="&#xE78B;" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock Style="{StaticResource SettingsNavCardPrimaryTextStyle}" Text="Output" />
                                <TextBlock Style="{StaticResource SettingsNavCardSecondaryTextStyle}" Text="Which display receives audience output" />
                            </StackPanel>
                            <FontIcon
                                Grid.Column="2"
                                Margin="12,0,0,0"
                                VerticalAlignment="Center"
                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Glyph="&#xE76C;" />
                        </Grid>
                    </Button>
                    <Button Click="Show_Click" Style="{StaticResource SettingsNavCardStyle}">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <FontIcon
                                Grid.Column="0"
                                Width="28"
                                Margin="0,0,14,0"
                                VerticalAlignment="Center"
                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                FontSize="20"
                                Glyph="&#xE8FD;" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock Style="{StaticResource SettingsNavCardPrimaryTextStyle}" Text="Show" />
                                <TextBlock Style="{StaticResource SettingsNavCardSecondaryTextStyle}" Text="Default view, thumbnails, and slide labels" />
                            </StackPanel>
                            <FontIcon
                                Grid.Column="2"
                                Margin="12,0,0,0"
                                VerticalAlignment="Center"
                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Glyph="&#xE76C;" />
                        </Grid>
                    </Button>
                    <Button Click="Editor_Click" Style="{StaticResource SettingsNavCardStyle}">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <FontIcon
                                Grid.Column="0"
                                Width="28"
                                Margin="0,0,14,0"
                                VerticalAlignment="Center"
                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                FontSize="20"
                                Glyph="&#xE70F;" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock Style="{StaticResource SettingsNavCardPrimaryTextStyle}" Text="Edit" />
                                <TextBlock Style="{StaticResource SettingsNavCardSecondaryTextStyle}" Text="Auto-save and editor grid" />
                            </StackPanel>
                            <FontIcon
                                Grid.Column="2"
                                Margin="12,0,0,0"
                                VerticalAlignment="Center"
                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Glyph="&#xE76C;" />
                        </Grid>
                    </Button>
                    <Button Click="Reflow_Click" Style="{StaticResource SettingsNavCardStyle}">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <FontIcon
                                Grid.Column="0"
                                Width="28"
                                Margin="0,0,14,0"
                                VerticalAlignment="Center"
                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                FontSize="20"
                                Glyph="&#xE149;" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock Style="{StaticResource SettingsNavCardPrimaryTextStyle}" Text="Reflow" />
                                <TextBlock Style="{StaticResource SettingsNavCardSecondaryTextStyle}" Text="Preview density and text size" />
                            </StackPanel>
                            <FontIcon
                                Grid.Column="2"
                                Margin="12,0,0,0"
                                VerticalAlignment="Center"
                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Glyph="&#xE76C;" />
                        </Grid>
                    </Button>
                </StackPanel>

                <StackPanel Spacing="10">
                    <TextBlock
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="App &amp; system" />
                    <Button Click="LibraryLocation_Click" Style="{StaticResource SettingsNavCardStyle}">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <FontIcon
                                Grid.Column="0"
                                Width="28"
                                Margin="0,0,14,0"
                                VerticalAlignment="Center"
                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                FontSize="20"
                                Glyph="&#xE8B7;" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock Style="{StaticResource SettingsNavCardPrimaryTextStyle}" Text="Library storage" />
                                <TextBlock Style="{StaticResource SettingsNavCardSecondaryTextStyle}" Text="Content root, audits, and maintenance log" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <InfoBadge
                                    x:Name="LibraryHealthBadge"
                                    Value="{x:Bind ViewModel.OutstandingIssueCount, Mode=OneWay}"
                                    Visibility="{x:Bind ViewModel.LibraryHealthBadgeVisibility, Mode=OneWay}" />
                                <FontIcon
                                    VerticalAlignment="Center"
                                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Glyph="&#xE76C;" />
                            </StackPanel>
                        </Grid>
                    </Button>
                    <Button Click="Integrations_Click" Style="{StaticResource SettingsNavCardStyle}">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <FontIcon
                                Grid.Column="0"
                                Width="28"
                                Margin="0,0,14,0"
                                VerticalAlignment="Center"
                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                FontSize="20"
                                Glyph="&#xE719;" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock Style="{StaticResource SettingsNavCardPrimaryTextStyle}" Text="Integrations" />
                                <TextBlock Style="{StaticResource SettingsNavCardSecondaryTextStyle}" Text="Music Manager and other connections" />
                            </StackPanel>
                            <FontIcon
                                Grid.Column="2"
                                Margin="12,0,0,0"
                                VerticalAlignment="Center"
                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Glyph="&#xE76C;" />
                        </Grid>
                    </Button>
                    <Button Click="Appearance_Click" Style="{StaticResource SettingsNavCardStyle}">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <FontIcon
                                Grid.Column="0"
                                Width="28"
                                Margin="0,0,14,0"
                                VerticalAlignment="Center"
                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                FontSize="20"
                                Glyph="&#xE790;" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock Style="{StaticResource SettingsNavCardPrimaryTextStyle}" Text="Appearance" />
                                <TextBlock Style="{StaticResource SettingsNavCardSecondaryTextStyle}" Text="Theme, recent files, and personalization" />
                            </StackPanel>
                            <FontIcon
                                Grid.Column="2"
                                Margin="12,0,0,0"
                                VerticalAlignment="Center"
                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Glyph="&#xE76C;" />
                        </Grid>
                    </Button>
                </StackPanel>

                <StackPanel Spacing="10">
                    <TextBlock
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="About" />
                    <!-- No extra details: static card only (no chevron). -->
                    <Border x:Name="AboutStaticCard" Style="{StaticResource SettingsAboutCardStyle}">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Border
                                Grid.Column="0"
                                Width="28"
                                Height="28"
                                Margin="0,0,14,0"
                                VerticalAlignment="Center"
                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                CornerRadius="4">
                                <FontIcon
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                    FontSize="16"
                                    Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                    Glyph="&#xE943;" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock
                                    x:Name="AboutStaticTitleText"
                                    Style="{StaticResource SettingsNavCardPrimaryTextStyle}"
                                    Text="Church Presenter" />
                                <TextBlock
                                    x:Name="AboutStaticSubtitleText"
                                    Style="{StaticResource SettingsNavCardSecondaryTextStyle}"
                                    Text=" " />
                            </StackPanel>
                            <TextBlock
                                x:Name="AboutStaticVersionText"
                                Grid.Column="2"
                                Margin="12,0,0,0"
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="0.0" />
                        </Grid>
                    </Border>
                    <!-- Dependencies / links: WinUI Expander provides the toggle chevron. -->
                    <Expander
                        x:Name="AboutExpanderCard"
                        Style="{StaticResource SettingsAboutExpanderStyle}"
                        Visibility="Collapsed">
                        <Expander.Header>
                            <!-- Fluent Expander header ToggleButton already applies ExpanderHeaderPadding (16,0,0,0) — same left inset as nav cards. We only add vertical 14 here to match SettingsNavCardStyle; do not pad left again. -->
                            <Grid Padding="0,14,0,14" ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                                <Border
                                    Grid.Column="0"
                                    Width="28"
                                    Height="28"
                                    Margin="0,0,14,0"
                                    VerticalAlignment="Center"
                                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                                    CornerRadius="4">
                                    <FontIcon
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                        FontSize="16"
                                        Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                        Glyph="&#xE943;" />
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                    <TextBlock
                                        x:Name="AboutExpanderTitleText"
                                        Style="{StaticResource SettingsNavCardPrimaryTextStyle}"
                                        Text="Church Presenter" />
                                    <TextBlock
                                        x:Name="AboutExpanderSubtitleText"
                                        Style="{StaticResource SettingsNavCardSecondaryTextStyle}"
                                        Text=" " />
                                </StackPanel>
                                <TextBlock
                                    x:Name="AboutExpanderVersionText"
                                    Grid.Column="2"
                                    Margin="12,0,2,0"
                                    VerticalAlignment="Center"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="0.0" />
                            </Grid>
                        </Expander.Header>
                        <Expander.Content>
                            <!-- Same 16px horizontal inset as nav rows (icon column); vertical insets match card padding rhythm. -->
                            <StackPanel Padding="16,14,16,14" Spacing="8">
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                    Text="Dependencies &amp; references" />
                                <ItemsControl x:Name="AboutDependencyItems">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock
                                                Margin="0,0,0,4"
                                                FontSize="14"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="{Binding}"
                                                TextWrapping="WrapWholeWords" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Vertical" Spacing="0" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                                <Border
                                    Height="1"
                                    Margin="0,2,0,0"
                                    HorizontalAlignment="Stretch"
                                    Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                                <HyperlinkButton
                                    Padding="2,4,2,4"
                                    HorizontalAlignment="Left"
                                    Content="Microsoft Privacy Statement"
                                    NavigateUri="https://privacy.microsoft.com/privacystatement" />
                            </StackPanel>
                        </Expander.Content>
                    </Expander>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
