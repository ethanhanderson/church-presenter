<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ChurchPresenter.Views.SettingsShowDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ChurchPresenter.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Padding="32,20,32,32">
        <Border x:Name="SettingsColumnRoot" VerticalAlignment="Stretch">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <local:SettingsDetailHeader
                    Grid.Row="0"
                    Margin="0,0,0,28"
                    CurrentSegmentText="Show" />

                <Border
                    x:Name="DetailContentRoot"
                    Grid.Row="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Top">
                    <StackPanel Spacing="16">
                        <Border
                            Padding="16"
                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <StackPanel Spacing="16">
                                <StackPanel Spacing="6">
                                    <TextBlock FontWeight="SemiBold" Text="Default center view" />
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="Content shown when nothing is selected in the center pane."
                                        TextWrapping="Wrap" />
                                    <ComboBox
                                        MinWidth="260"
                                        HorizontalAlignment="Left"
                                        ItemsSource="{x:Bind ViewModel.ShowCenterViewChoices, Mode=OneWay}"
                                        SelectedItem="{x:Bind ViewModel.ShowDefaultCenterView, Mode=TwoWay}" />
                                </StackPanel>

                                <StackPanel Spacing="8">
                                    <TextBlock FontWeight="SemiBold" Text="Slide thumbnail size" />
                                    <Slider
                                        Maximum="320"
                                        Minimum="140"
                                        StepFrequency="20"
                                        Value="{x:Bind ViewModel.ShowThumbnailSize, Mode=TwoWay}" />
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="{x:Bind ViewModel.ShowThumbnailSize, Mode=OneWay}" />
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="px" />
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Spacing="4">
                                    <ToggleSwitch Header="Show slide labels" IsOn="{x:Bind ViewModel.ShowSlideLabels, Mode=TwoWay}" />
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="Display section labels on thumbnails."
                                        TextWrapping="Wrap" />
                                </StackPanel>

                                <StackPanel Spacing="4">
                                    <ToggleSwitch Header="Double-click takes live" IsOn="{x:Bind ViewModel.ShowAutoTakeOnDoubleClick, Mode=TwoWay}" />
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="Send the slide live when double-clicked in Show mode."
                                        TextWrapping="Wrap" />
                                </StackPanel>

                                <StackPanel Spacing="8">
                                    <TextBlock FontWeight="SemiBold" Text="Media seek interval" />
                                    <Slider
                                        Maximum="60"
                                        Minimum="1"
                                        StepFrequency="1"
                                        Value="{x:Bind ViewModel.ShowMediaSeekSeconds, Mode=TwoWay}" />
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="{x:Bind ViewModel.ShowMediaSeekSeconds, Mode=OneWay}" />
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="seconds" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
