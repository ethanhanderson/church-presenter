<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ChurchPresenter.Views.SettingsEditorDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ChurchPresenter.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Padding="32,20,32,32">
        <Border x:Name="SettingsColumnRoot" VerticalAlignment="Stretch">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <local:SettingsDetailHeader
                    Grid.Row="0"
                    Margin="0,0,0,28"
                    CurrentSegmentText="Edit" />

                <Border
                    x:Name="DetailContentRoot"
                    Grid.Row="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Top">
                    <StackPanel Spacing="16">
                        <Border
                            Padding="16"
                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <StackPanel Spacing="16">
                                <StackPanel Spacing="4">
                                    <ToggleSwitch Header="Auto-save" IsOn="{x:Bind ViewModel.EditorAutoSaveEnabled, Mode=TwoWay}" />
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="Automatically save presentations while you edit."
                                        TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <ToggleSwitch Header="Save on create / import" IsOn="{x:Bind ViewModel.EditorAutoSaveOnCreate, Mode=TwoWay}" />
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="Save new presentations when created or imported."
                                        TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Spacing="8">
                                    <TextBlock FontWeight="SemiBold" Text="Autosave interval (seconds)" />
                                    <Slider
                                        Maximum="120"
                                        Minimum="10"
                                        StepFrequency="5"
                                        Value="{x:Bind ViewModel.EditorAutosaveInterval, Mode=TwoWay}" />
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="{x:Bind ViewModel.EditorAutosaveInterval, Mode=OneWay}" />
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="s" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border
                            Padding="16"
                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <StackPanel Spacing="16">
                                <StackPanel Spacing="4">
                                    <ToggleSwitch Header="Show grid" IsOn="{x:Bind ViewModel.EditorShowGrid, Mode=TwoWay}" />
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="Display alignment grid on the slide canvas."
                                        TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <ToggleSwitch Header="Snap to grid" IsOn="{x:Bind ViewModel.EditorSnapToGrid, Mode=TwoWay}" />
                                </StackPanel>
                                <StackPanel Spacing="8">
                                    <TextBlock FontWeight="SemiBold" Text="Grid size (pixels)" />
                                    <Slider
                                        Maximum="50"
                                        Minimum="5"
                                        StepFrequency="5"
                                        Value="{x:Bind ViewModel.EditorGridSize, Mode=TwoWay}" />
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="{x:Bind ViewModel.EditorGridSize, Mode=OneWay}" />
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="px" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
