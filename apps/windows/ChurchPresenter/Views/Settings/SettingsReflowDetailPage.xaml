<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ChurchPresenter.Views.SettingsReflowDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ChurchPresenter.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Padding="32,20,32,32">
        <Border x:Name="SettingsColumnRoot" VerticalAlignment="Stretch">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <local:SettingsDetailHeader
                    Grid.Row="0"
                    Margin="0,0,0,28"
                    CurrentSegmentText="Reflow" />

                <Border
                    x:Name="DetailContentRoot"
                    Grid.Row="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Top">
                    <StackPanel Spacing="16">
                        <Border
                            Padding="16"
                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <StackPanel Spacing="16">
                                <StackPanel Spacing="8">
                                    <TextBlock FontWeight="SemiBold" Text="Text size" />
                                    <Slider
                                        Maximum="18"
                                        Minimum="11"
                                        StepFrequency="1"
                                        Value="{x:Bind ViewModel.ReflowTextSize, Mode=TwoWay}" />
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="{x:Bind ViewModel.ReflowTextSize, Mode=OneWay}" />
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="px" />
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Spacing="6">
                                    <TextBlock FontWeight="SemiBold" Text="Preview density" />
                                    <ComboBox
                                        MinWidth="260"
                                        HorizontalAlignment="Left"
                                        ItemsSource="{x:Bind ViewModel.ReflowDensityChoices, Mode=OneWay}"
                                        SelectedItem="{x:Bind ViewModel.ReflowPreviewDensity, Mode=TwoWay}" />
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <ToggleSwitch Header="Show slide labels" IsOn="{x:Bind ViewModel.ReflowShowSlideLabels, Mode=TwoWay}" />
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="Display section labels on slide previews in Reflow."
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
