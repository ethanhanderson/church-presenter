<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ChurchPresenter.Views.SettingsOutputPage"
    x:Name="ThisPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ChurchPresenter.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:ChurchPresenter.ViewModels"
    mc:Ignorable="d"
    Background="Transparent">
    <Page.Resources>
        <!-- No additional converters needed — MonitorCardItem exposes pre-computed opacity/bool fields. -->
    </Page.Resources>

    <Grid Padding="32,20,32,32">
        <Border x:Name="SettingsColumnRoot" VerticalAlignment="Stretch">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <local:SettingsDetailHeader
                    Grid.Row="0"
                    Margin="0,0,0,28"
                    CurrentSegmentText="Output" />

                <ScrollViewer
                    Grid.Row="1"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="32">

                        <!-- ═══════════════════════════════════════════ Audience Output -->
                        <StackPanel Spacing="10">
                            <TextBlock
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Audience Output" />

                            <!-- Monitor card strip -->
                            <Border Style="{StaticResource SettingsAboutCardStyle}">
                                <StackPanel Spacing="12">
                                    <TextBlock
                                        Style="{StaticResource SettingsNavCardSecondaryTextStyle}"
                                        Text="Select which display receives the audience output. Click a monitor card to assign it." />

                                    <!-- Horizontal strip of individual monitor cards -->
                                    <ScrollViewer
                                        HorizontalScrollBarVisibility="Auto"
                                        VerticalScrollBarVisibility="Disabled"
                                        HorizontalScrollMode="Enabled"
                                        VerticalScrollMode="Disabled">
                                        <ItemsControl
                                            x:Name="AudienceMonitorCardStrip"
                                            ItemsSource="{x:Bind ViewModel.AudienceMonitorCards, Mode=OneWay}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" Spacing="8" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:MonitorCardItem">
                                                    <Button
                                                        Width="{x:Bind CardWidth, Mode=OneTime}"
                                                        Height="{x:Bind CardHeight, Mode=OneTime}"
                                                        Padding="0"
                                                        AutomationProperties.Name="{x:Bind DisplayName, Mode=OneTime}"
                                                        Click="AudienceMonitorCard_Click"
                                                        CornerRadius="8"
                                                        IsEnabled="{x:Bind IsEnabled, Mode=OneTime}"
                                                        Opacity="{x:Bind ContentOpacity, Mode=OneTime}"
                                                        Tag="{x:Bind Index}">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
                                                                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                                                                <Setter Property="BorderThickness" Value="1.5" />
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border
                                                                                x:Name="Root"
                                                                                Background="{TemplateBinding Background}"
                                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                                CornerRadius="8">
                                                                                <ContentPresenter />
                                                                            </Border>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Style>
                                                        </Button.Style>
                                                        <Grid>
                                                            <!-- Card inner content -->
                                                            <StackPanel
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                Spacing="4">
                                                                <FontIcon
                                                                    HorizontalAlignment="Center"
                                                                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                                    FontSize="20"
                                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                    Glyph="&#xE7F4;" />
                                                                <TextBlock
                                                                    HorizontalAlignment="Center"
                                                                    FontSize="11"
                                                                    FontWeight="SemiBold"
                                                                    Text="{x:Bind DisplayName, Mode=OneTime}"
                                                                    TextAlignment="Center"
                                                                    TextTrimming="CharacterEllipsis"
                                                                    MaxWidth="88" />
                                                                <TextBlock
                                                                    HorizontalAlignment="Center"
                                                                    FontSize="10"
                                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                    Text="{x:Bind ResolutionText, Mode=OneTime}"
                                                                    TextAlignment="Center"
                                                                    TextTrimming="CharacterEllipsis"
                                                                    MaxWidth="88" />
                                                            </StackPanel>

                                                            <!-- Selected checkmark overlay -->
                                                            <Border
                                                                HorizontalAlignment="Stretch"
                                                                VerticalAlignment="Stretch"
                                                                BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                                                                BorderThickness="2"
                                                                CornerRadius="8"
                                                                Opacity="{x:Bind CheckmarkOpacity, Mode=OneTime}" />
                                                            <FontIcon
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Top"
                                                                Margin="0,6,6,0"
                                                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                                FontSize="12"
                                                                Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                                                Glyph="&#xE73E;"
                                                                Opacity="{x:Bind CheckmarkOpacity, Mode=OneTime}" />

                                                            <!-- Excluded (stage-assigned) indicator -->
                                                            <TextBlock
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Bottom"
                                                                Margin="0,0,0,6"
                                                                FontSize="9"
                                                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                                Text="Used by Stage"
                                                                Opacity="{x:Bind ExcludedLabelOpacity, Mode=OneTime}" />
                                                        </Grid>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>

                            <!-- Audience monitor picker setting card -->
                            <Border Style="{StaticResource SettingsAboutCardStyle}">
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                                    <FontIcon
                                        Grid.Column="0"
                                        VerticalAlignment="Center"
                                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                        FontSize="20"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Glyph="&#xE7F4;" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Style="{StaticResource SettingsNavCardPrimaryTextStyle}" Text="Output display" />
                                        <TextBlock
                                            Style="{StaticResource SettingsNavCardSecondaryTextStyle}"
                                            Text="Choose which display receives the audience output."
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                    <Button
                                        Grid.Column="2"
                                        HorizontalAlignment="Right"
                                        HorizontalContentAlignment="Stretch"
                                        Padding="12,10"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                        <Button.Flyout>
                                            <Flyout
                                                x:Name="AudienceOutputDisplayFlyout"
                                                Closed="AudienceOutputDisplayFlyout_Closed"
                                                Placement="BottomEdgeAlignedRight">
                                                <Flyout.FlyoutPresenterStyle>
                                                    <Style TargetType="FlyoutPresenter">
                                                        <Setter Property="CornerRadius" Value="8" />
                                                        <Setter Property="Padding" Value="8" />
                                                        <Setter Property="MinWidth" Value="0" />
                                                        <Setter Property="MaxWidth" Value="99999" />
                                                        <Setter Property="MaxHeight" Value="99999" />
                                                        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
                                                        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
                                                        <Setter Property="ScrollViewer.HorizontalScrollMode" Value="Disabled" />
                                                        <Setter Property="ScrollViewer.VerticalScrollMode" Value="Disabled" />
                                                    </Style>
                                                </Flyout.FlyoutPresenterStyle>
                                                <Grid>
                                                    <Grid.KeyboardAccelerators>
                                                        <KeyboardAccelerator Key="Escape" Invoked="AudienceOutputDisplayFlyout_EscapeInvoked" />
                                                    </Grid.KeyboardAccelerators>
                                                    <ItemsControl ItemsSource="{x:Bind ViewModel.MonitorLayoutItems, Mode=OneWay}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <StackPanel Spacing="6" />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="vm:MonitorLayoutItem">
                                                                <Border
                                                                    HorizontalAlignment="Stretch"
                                                                    Padding="12,10"
                                                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="8"
                                                                    PointerCanceled="AudienceMonitorOptionRow_PointerCanceled"
                                                                    PointerEntered="AudienceMonitorOptionRow_PointerEntered"
                                                                    PointerExited="AudienceMonitorOptionRow_PointerExited">
                                                                    <Grid Background="Transparent" ColumnDefinitions="Auto,*,Auto,Auto">
                                                                        <Button
                                                                            Grid.Column="0"
                                                                            Grid.ColumnSpan="2"
                                                                            Margin="0,0,12,0"
                                                                            Padding="0"
                                                                            HorizontalAlignment="Stretch"
                                                                            HorizontalContentAlignment="Stretch"
                                                                            VerticalAlignment="Stretch"
                                                                            AutomationProperties.Name="{x:Bind DisplayName, Mode=OneTime}"
                                                                            Background="Transparent"
                                                                            BorderThickness="0"
                                                                            Click="AudienceMonitorOptionButton_Click"
                                                                            Tag="{x:Bind Index}">
                                                                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                                                                <Border
                                                                                    Grid.Column="0"
                                                                                    Width="{x:Bind PreviewCanvasWidth, Mode=OneTime}"
                                                                                    Height="{x:Bind PreviewCanvasHeight, Mode=OneTime}"
                                                                                    VerticalAlignment="Center"
                                                                                    Background="{ThemeResource LayerFillColorAltBrush}"
                                                                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                                                    BorderThickness="1"
                                                                                    CornerRadius="6">
                                                                                    <ItemsControl
                                                                                        Width="{x:Bind PreviewCanvasWidth, Mode=OneTime}"
                                                                                        Height="{x:Bind PreviewCanvasHeight, Mode=OneTime}"
                                                                                        ItemsSource="{x:Bind PreviewTiles, Mode=OneTime}">
                                                                                        <ItemsControl.ItemsPanel>
                                                                                            <ItemsPanelTemplate>
                                                                                                <Canvas />
                                                                                            </ItemsPanelTemplate>
                                                                                        </ItemsControl.ItemsPanel>
                                                                                        <ItemsControl.ItemTemplate>
                                                                                            <DataTemplate x:DataType="vm:MonitorPreviewTile">
                                                                                                <Grid
                                                                                                    Width="{x:Bind Width, Mode=OneTime}"
                                                                                                    Height="{x:Bind Height, Mode=OneTime}"
                                                                                                    HorizontalAlignment="Left"
                                                                                                    VerticalAlignment="Top">
                                                                                                    <Grid.RenderTransform>
                                                                                                        <TranslateTransform
                                                                                                            X="{x:Bind CanvasLeft, Mode=OneTime}"
                                                                                                            Y="{x:Bind CanvasTop, Mode=OneTime}" />
                                                                                                    </Grid.RenderTransform>
                                                                                                    <Border
                                                                                                        Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                                                                                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                                                                        BorderThickness="1"
                                                                                                        CornerRadius="2" />
                                                                                                    <Border
                                                                                                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                                                                        CornerRadius="2"
                                                                                                        Opacity="{x:Bind HighlightOpacity, Mode=OneTime}" />
                                                                                                </Grid>
                                                                                            </DataTemplate>
                                                                                        </ItemsControl.ItemTemplate>
                                                                                    </ItemsControl>
                                                                                </Border>
                                                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                                                                    <TextBlock
                                                                                        Style="{StaticResource SettingsNavCardPrimaryTextStyle}"
                                                                                        Text="{x:Bind DisplayName, Mode=OneTime}"
                                                                                        TextTrimming="CharacterEllipsis" />
                                                                                    <TextBlock
                                                                                        Style="{StaticResource SettingsNavCardSecondaryTextStyle}"
                                                                                        Text="{x:Bind ResolutionText, Mode=OneTime}" />
                                                                                </StackPanel>
                                                                            </Grid>
                                                                        </Button>
                                                                        <Button
                                                                            x:Name="AudienceIdentifyButton"
                                                                            Grid.Column="2"
                                                                            Margin="0,0,12,0"
                                                                            HorizontalAlignment="Right"
                                                                            VerticalAlignment="Center"
                                                                            MinHeight="28"
                                                                            Padding="6,4"
                                                                            FontSize="12"
                                                                            Click="AudienceIdentifyButton_Click"
                                                                            Content="Identify"
                                                                            IsHitTestVisible="False"
                                                                            Opacity="0"
                                                                            Style="{StaticResource DefaultButtonStyle}"
                                                                            Tag="{x:Bind Index}" />
                                                                        <FontIcon
                                                                            Grid.Column="3"
                                                                            Width="20"
                                                                            VerticalAlignment="Center"
                                                                            HorizontalAlignment="Center"
                                                                            FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                                            Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                                                            Glyph="&#xE73E;"
                                                                            IsHitTestVisible="False"
                                                                            Opacity="{x:Bind CheckmarkOpacity, Mode=OneTime}" />
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Grid>
                                            </Flyout>
                                        </Button.Flyout>
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                            <StackPanel Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="0">
                                                <TextBlock
                                                    HorizontalAlignment="Right"
                                                    FontWeight="SemiBold"
                                                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                    TextTrimming="CharacterEllipsis"
                                                    Text="{x:Bind ViewModel.AudienceSelectedMonitorButtonTitle, Mode=OneWay}" />
                                            </StackPanel>
                                            <FontIcon
                                                Grid.Column="1"
                                                VerticalAlignment="Center"
                                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                Glyph="&#xE70D;" />
                                        </Grid>
                                    </Button>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- ═══════════════════════════════════════════ Stage Output -->
                        <StackPanel Spacing="10">
                            <TextBlock
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Stage Output" />

                            <!-- Monitor card strip -->
                            <Border Style="{StaticResource SettingsAboutCardStyle}">
                                <StackPanel Spacing="12">
                                    <TextBlock
                                        Style="{StaticResource SettingsNavCardSecondaryTextStyle}"
                                        Text="Select which display receives the stage output. A monitor assigned to audience cannot be assigned to stage." />

                                    <ScrollViewer
                                        HorizontalScrollBarVisibility="Auto"
                                        VerticalScrollBarVisibility="Disabled"
                                        HorizontalScrollMode="Enabled"
                                        VerticalScrollMode="Disabled">
                                        <ItemsControl
                                            x:Name="StageMonitorCardStrip"
                                            ItemsSource="{x:Bind ViewModel.StageMonitorCards, Mode=OneWay}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" Spacing="8" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:MonitorCardItem">
                                                    <Button
                                                        Width="{x:Bind CardWidth, Mode=OneTime}"
                                                        Height="{x:Bind CardHeight, Mode=OneTime}"
                                                        Padding="0"
                                                        AutomationProperties.Name="{x:Bind DisplayName, Mode=OneTime}"
                                                        Click="StageMonitorCard_Click"
                                                        CornerRadius="8"
                                                        IsEnabled="{x:Bind IsEnabled, Mode=OneTime}"
                                                        Opacity="{x:Bind ContentOpacity, Mode=OneTime}"
                                                        Tag="{x:Bind Index}">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
                                                                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                                                                <Setter Property="BorderThickness" Value="1.5" />
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border
                                                                                x:Name="Root"
                                                                                Background="{TemplateBinding Background}"
                                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                                CornerRadius="8">
                                                                                <ContentPresenter />
                                                                            </Border>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Style>
                                                        </Button.Style>
                                                        <Grid>
                                                            <StackPanel
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                Spacing="4">
                                                                <FontIcon
                                                                    HorizontalAlignment="Center"
                                                                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                                    FontSize="20"
                                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                    Glyph="&#xE7F4;" />
                                                                <TextBlock
                                                                    HorizontalAlignment="Center"
                                                                    FontSize="11"
                                                                    FontWeight="SemiBold"
                                                                    Text="{x:Bind DisplayName, Mode=OneTime}"
                                                                    TextAlignment="Center"
                                                                    TextTrimming="CharacterEllipsis"
                                                                    MaxWidth="88" />
                                                                <TextBlock
                                                                    HorizontalAlignment="Center"
                                                                    FontSize="10"
                                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                    Text="{x:Bind ResolutionText, Mode=OneTime}"
                                                                    TextAlignment="Center"
                                                                    TextTrimming="CharacterEllipsis"
                                                                    MaxWidth="88" />
                                                            </StackPanel>

                                                            <Border
                                                                HorizontalAlignment="Stretch"
                                                                VerticalAlignment="Stretch"
                                                                BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                                                                BorderThickness="2"
                                                                CornerRadius="8"
                                                                Opacity="{x:Bind CheckmarkOpacity, Mode=OneTime}" />
                                                            <FontIcon
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Top"
                                                                Margin="0,6,6,0"
                                                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                                FontSize="12"
                                                                Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                                                Glyph="&#xE73E;"
                                                                Opacity="{x:Bind CheckmarkOpacity, Mode=OneTime}" />

                                                            <TextBlock
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Bottom"
                                                                Margin="0,0,0,6"
                                                                FontSize="9"
                                                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                                Text="Used by Audience"
                                                                Opacity="{x:Bind ExcludedLabelOpacity, Mode=OneTime}" />
                                                        </Grid>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>

                            <!-- Stage monitor picker setting card -->
                            <Border Style="{StaticResource SettingsAboutCardStyle}">
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                                    <FontIcon
                                        Grid.Column="0"
                                        VerticalAlignment="Center"
                                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                        FontSize="20"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Glyph="&#xE7F4;" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Style="{StaticResource SettingsNavCardPrimaryTextStyle}" Text="Stage display" />
                                        <TextBlock
                                            Style="{StaticResource SettingsNavCardSecondaryTextStyle}"
                                            Text="Choose which display receives the stage output."
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                    <Button
                                        Grid.Column="2"
                                        HorizontalAlignment="Right"
                                        HorizontalContentAlignment="Stretch"
                                        Padding="12,10"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                        <Button.Flyout>
                                            <Flyout
                                                x:Name="StageOutputDisplayFlyout"
                                                Closed="StageOutputDisplayFlyout_Closed"
                                                Placement="BottomEdgeAlignedRight">
                                                <Flyout.FlyoutPresenterStyle>
                                                    <Style TargetType="FlyoutPresenter">
                                                        <Setter Property="CornerRadius" Value="8" />
                                                        <Setter Property="Padding" Value="8" />
                                                        <Setter Property="MinWidth" Value="0" />
                                                        <Setter Property="MaxWidth" Value="99999" />
                                                        <Setter Property="MaxHeight" Value="99999" />
                                                        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
                                                        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
                                                        <Setter Property="ScrollViewer.HorizontalScrollMode" Value="Disabled" />
                                                        <Setter Property="ScrollViewer.VerticalScrollMode" Value="Disabled" />
                                                    </Style>
                                                </Flyout.FlyoutPresenterStyle>
                                                <Grid>
                                                    <Grid.KeyboardAccelerators>
                                                        <KeyboardAccelerator Key="Escape" Invoked="StageOutputDisplayFlyout_EscapeInvoked" />
                                                    </Grid.KeyboardAccelerators>
                                                    <ItemsControl ItemsSource="{x:Bind ViewModel.StageMonitorLayoutItems, Mode=OneWay}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <StackPanel Spacing="6" />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="vm:MonitorLayoutItem">
                                                                <Border
                                                                    HorizontalAlignment="Stretch"
                                                                    Padding="12,10"
                                                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="8"
                                                                    PointerCanceled="StageMonitorOptionRow_PointerCanceled"
                                                                    PointerEntered="StageMonitorOptionRow_PointerEntered"
                                                                    PointerExited="StageMonitorOptionRow_PointerExited">
                                                                    <Grid Background="Transparent" ColumnDefinitions="Auto,*,Auto,Auto">
                                                                        <Button
                                                                            Grid.Column="0"
                                                                            Grid.ColumnSpan="2"
                                                                            Margin="0,0,12,0"
                                                                            Padding="0"
                                                                            HorizontalAlignment="Stretch"
                                                                            HorizontalContentAlignment="Stretch"
                                                                            VerticalAlignment="Stretch"
                                                                            AutomationProperties.Name="{x:Bind DisplayName, Mode=OneTime}"
                                                                            Background="Transparent"
                                                                            BorderThickness="0"
                                                                            Click="StageMonitorOptionButton_Click"
                                                                            Tag="{x:Bind Index}">
                                                                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                                                                <Border
                                                                                    Grid.Column="0"
                                                                                    Width="{x:Bind PreviewCanvasWidth, Mode=OneTime}"
                                                                                    Height="{x:Bind PreviewCanvasHeight, Mode=OneTime}"
                                                                                    VerticalAlignment="Center"
                                                                                    Background="{ThemeResource LayerFillColorAltBrush}"
                                                                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                                                    BorderThickness="1"
                                                                                    CornerRadius="6">
                                                                                    <ItemsControl
                                                                                        Width="{x:Bind PreviewCanvasWidth, Mode=OneTime}"
                                                                                        Height="{x:Bind PreviewCanvasHeight, Mode=OneTime}"
                                                                                        ItemsSource="{x:Bind PreviewTiles, Mode=OneTime}">
                                                                                        <ItemsControl.ItemsPanel>
                                                                                            <ItemsPanelTemplate>
                                                                                                <Canvas />
                                                                                            </ItemsPanelTemplate>
                                                                                        </ItemsControl.ItemsPanel>
                                                                                        <ItemsControl.ItemTemplate>
                                                                                            <DataTemplate x:DataType="vm:MonitorPreviewTile">
                                                                                                <Grid
                                                                                                    Width="{x:Bind Width, Mode=OneTime}"
                                                                                                    Height="{x:Bind Height, Mode=OneTime}"
                                                                                                    HorizontalAlignment="Left"
                                                                                                    VerticalAlignment="Top">
                                                                                                    <Grid.RenderTransform>
                                                                                                        <TranslateTransform
                                                                                                            X="{x:Bind CanvasLeft, Mode=OneTime}"
                                                                                                            Y="{x:Bind CanvasTop, Mode=OneTime}" />
                                                                                                    </Grid.RenderTransform>
                                                                                                    <Border
                                                                                                        Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                                                                                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                                                                        BorderThickness="1"
                                                                                                        CornerRadius="2" />
                                                                                                    <Border
                                                                                                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                                                                        CornerRadius="2"
                                                                                                        Opacity="{x:Bind HighlightOpacity, Mode=OneTime}" />
                                                                                                </Grid>
                                                                                            </DataTemplate>
                                                                                        </ItemsControl.ItemTemplate>
                                                                                    </ItemsControl>
                                                                                </Border>
                                                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                                                                    <TextBlock
                                                                                        Style="{StaticResource SettingsNavCardPrimaryTextStyle}"
                                                                                        Text="{x:Bind DisplayName, Mode=OneTime}"
                                                                                        TextTrimming="CharacterEllipsis" />
                                                                                    <TextBlock
                                                                                        Style="{StaticResource SettingsNavCardSecondaryTextStyle}"
                                                                                        Text="{x:Bind ResolutionText, Mode=OneTime}" />
                                                                                </StackPanel>
                                                                            </Grid>
                                                                        </Button>
                                                                        <Button
                                                                            x:Name="StageIdentifyButton"
                                                                            Grid.Column="2"
                                                                            Margin="0,0,12,0"
                                                                            HorizontalAlignment="Right"
                                                                            VerticalAlignment="Center"
                                                                            MinHeight="28"
                                                                            Padding="6,4"
                                                                            FontSize="12"
                                                                            Click="StageIdentifyButton_Click"
                                                                            Content="Identify"
                                                                            IsHitTestVisible="False"
                                                                            Opacity="0"
                                                                            Style="{StaticResource DefaultButtonStyle}"
                                                                            Tag="{x:Bind Index}" />
                                                                        <FontIcon
                                                                            Grid.Column="3"
                                                                            Width="20"
                                                                            VerticalAlignment="Center"
                                                                            HorizontalAlignment="Center"
                                                                            FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                                            Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                                                            Glyph="&#xE73E;"
                                                                            IsHitTestVisible="False"
                                                                            Opacity="{x:Bind CheckmarkOpacity, Mode=OneTime}" />
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Grid>
                                            </Flyout>
                                        </Button.Flyout>
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                            <StackPanel Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="0">
                                                <TextBlock
                                                    HorizontalAlignment="Right"
                                                    FontWeight="SemiBold"
                                                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                    TextTrimming="CharacterEllipsis"
                                                    Text="{x:Bind ViewModel.StageSelectedMonitorButtonTitle, Mode=OneWay}" />
                                            </StackPanel>
                                            <FontIcon
                                                Grid.Column="1"
                                                VerticalAlignment="Center"
                                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                Glyph="&#xE70D;" />
                                        </Grid>
                                    </Button>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- ═══════════════════════════════════════════ Looks -->
                        <StackPanel Spacing="10">
                            <TextBlock
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Looks" />

                            <Border Style="{StaticResource SettingsAboutCardStyle}">
                                <StackPanel Spacing="14">
                                    <TextBlock
                                        Style="{StaticResource SettingsNavCardSecondaryTextStyle}"
                                        Text="Configure which layers appear on each audience screen. Mask assignments live here instead of in the preview clear buttons." />

                                    <ItemsControl ItemsSource="{x:Bind ViewModel.LookScreenRoutes, Mode=OneWay}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Spacing="10" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:OutputLookScreenRouteSettingsItem">
                                                <Border
                                                    Padding="12"
                                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8">
                                                    <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                                                        <TextBlock
                                                            FontWeight="SemiBold"
                                                            Text="{x:Bind DisplayName, Mode=OneWay}" />
                                                        <Grid
                                                            Grid.Row="1"
                                                            ColumnDefinitions="Auto,Auto,Auto,*,*"
                                                            ColumnSpacing="14"
                                                            RowSpacing="6">
                                                            <CheckBox
                                                                Content="Slide"
                                                                IsChecked="{x:Bind SlideEnabled, Mode=TwoWay}"
                                                                Click="LookRouteField_Click" />
                                                            <CheckBox
                                                                Grid.Column="1"
                                                                Content="Media"
                                                                IsChecked="{x:Bind MediaEnabled, Mode=TwoWay}"
                                                                Click="LookRouteField_Click" />
                                                            <CheckBox
                                                                Grid.Column="2"
                                                                Content="Mask"
                                                                IsChecked="{x:Bind MaskEnabled, Mode=TwoWay}"
                                                                Click="LookRouteField_Click" />
                                                            <TextBox
                                                                Grid.Column="3"
                                                                Header="Slide theme variant"
                                                                PlaceholderText="Default"
                                                                Text="{x:Bind SlideThemeVariantId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                TextChanged="LookRouteField_TextChanged" />
                                                            <TextBox
                                                                Grid.Column="4"
                                                                Header="Mask id"
                                                                PlaceholderText="No mask"
                                                                Text="{x:Bind MaskId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                TextChanged="LookRouteField_TextChanged" />
                                                        </Grid>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ═══════════════════════════════════════════ Clear Groups -->
                        <StackPanel Spacing="10">
                            <TextBlock
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Clear Groups" />

                            <Border Style="{StaticResource SettingsAboutCardStyle}">
                                <Grid ColumnDefinitions="260,*" ColumnSpacing="18" MinHeight="360">
                                    <Grid Grid.Column="0" RowDefinitions="Auto,*" RowSpacing="10">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                Style="{StaticResource SettingsNavCardPrimaryTextStyle}"
                                                Text="Clear Groups" />
                                            <Button
                                                Grid.Column="1"
                                                MinWidth="32"
                                                Padding="8,4"
                                                AutomationProperties.Name="Add clear group"
                                                Click="AddClearGroup_Click"
                                                Content="+" />
                                        </Grid>
                                        <ListView
                                            Grid.Row="1"
                                            ItemsSource="{x:Bind ViewModel.ClearGroups, Mode=OneWay}"
                                            SelectedItem="{x:Bind ViewModel.SelectedClearGroup, Mode=TwoWay}"
                                            SelectionChanged="ClearGroupsList_SelectionChanged">
                                            <ListView.ItemTemplate>
                                                <DataTemplate x:DataType="vm:ClearGroupSettingsItem">
                                                    <Grid Padding="8,6" ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                                        <FontIcon
                                                            Grid.Column="0"
                                                            Width="20"
                                                            VerticalAlignment="Center"
                                                            FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                            FontSize="16"
                                                            Glyph="{x:Bind Icon, Mode=OneWay}" />
                                                        <TextBlock
                                                            Grid.Column="1"
                                                            VerticalAlignment="Center"
                                                            Text="{x:Bind Name, Mode=OneWay}"
                                                            TextTrimming="CharacterEllipsis" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                    </Grid>

                                    <StackPanel Grid.Column="1" Spacing="14">
                                        <TextBlock
                                            Style="{StaticResource SettingsNavCardSecondaryTextStyle}"
                                            Text="Choose which output layers and playback scopes this clear action should reset." />

                                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="8">
                                            <TextBlock Grid.Row="0" VerticalAlignment="Center" Text="Name:" />
                                            <TextBox
                                                Grid.Row="0"
                                                Grid.Column="1"
                                                IsEnabled="{x:Bind ViewModel.HasSelectedClearGroup, Mode=OneWay}"
                                                Text="{x:Bind ViewModel.SelectedClearGroup.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                TextChanged="ClearGroupField_TextChanged" />

                                            <TextBlock Grid.Row="1" VerticalAlignment="Center" Text="Icon:" />
                                            <TextBox
                                                Grid.Row="1"
                                                Grid.Column="1"
                                                MaxWidth="160"
                                                HorizontalAlignment="Left"
                                                IsEnabled="{x:Bind ViewModel.HasSelectedClearGroup, Mode=OneWay}"
                                                Text="{x:Bind ViewModel.SelectedClearGroup.Icon, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                TextChanged="ClearGroupField_TextChanged" />

                                            <TextBlock Grid.Row="2" VerticalAlignment="Center" Text="Tint:" />
                                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                                <CheckBox
                                                    Content="Use tint"
                                                    IsEnabled="{x:Bind ViewModel.HasSelectedClearGroup, Mode=OneWay}"
                                                    IsChecked="{x:Bind ViewModel.SelectedClearGroup.TintEnabled, Mode=TwoWay}"
                                                    Click="ClearGroupField_Click" />
                                                <TextBox
                                                    Width="110"
                                                    IsEnabled="{x:Bind ViewModel.HasSelectedClearGroup, Mode=OneWay}"
                                                    Text="{x:Bind ViewModel.SelectedClearGroup.TintColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    TextChanged="ClearGroupField_TextChanged" />
                                            </StackPanel>
                                        </Grid>

                                        <ItemsControl ItemsSource="{x:Bind ViewModel.SelectedClearGroup.Scopes, Mode=OneWay}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Spacing="4" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:ClearScopeSettingsItem">
                                                    <CheckBox
                                                        Content="{x:Bind DisplayName, Mode=OneWay}"
                                                        IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                                        Click="ClearGroupField_Click" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <StackPanel Spacing="4">
                                            <CheckBox
                                                Content="Stop presentation timeline when clearing Presentation"
                                                IsEnabled="{x:Bind ViewModel.HasSelectedClearGroup, Mode=OneWay}"
                                                IsChecked="{x:Bind ViewModel.SelectedClearGroup.StopPresentationTimeline, Mode=TwoWay}"
                                                Click="ClearGroupField_Click" />
                                            <CheckBox
                                                Content="Stop announcement timeline when clearing Announcements"
                                                IsEnabled="{x:Bind ViewModel.HasSelectedClearGroup, Mode=OneWay}"
                                                IsChecked="{x:Bind ViewModel.SelectedClearGroup.StopAnnouncementTimeline, Mode=TwoWay}"
                                                Click="ClearGroupField_Click" />
                                        </StackPanel>

                                        <Button
                                            HorizontalAlignment="Left"
                                            IsEnabled="{x:Bind ViewModel.HasSelectedClearGroup, Mode=OneWay}"
                                            Click="DeleteClearGroup_Click"
                                            Content="Delete clear group" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Page>
