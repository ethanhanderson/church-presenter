<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ChurchPresenter.Views.OutputPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ChurchPresenter.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:DataType="local:OutputPage"
    mc:Ignorable="d"
    Background="Black"
    IsTabStop="True"
    KeyDown="Page_KeyDown"
    KeyUp="Page_KeyUp">
    <Grid>
        <local:ProgramOutputSurface
            IsHitTestVisible="False"
            PlaybackRegistrationMode="Mirror"
            ViewModel="{x:Bind ViewModel, Mode=OneWay}" />

        <!-- Captures pointer movement so the close affordance can fade in when the operator hovers the output window. -->
        <Grid
            x:Name="PointerOverlay"
            Background="Transparent"
            PointerEntered="PointerOverlay_PointerEntered"
            PointerMoved="PointerOverlay_PointerMoved"
            PointerExited="PointerOverlay_PointerExited">
            <Grid
                x:Name="CloseAudienceChrome"
                Width="64"
                Height="64"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,24,24"
                Opacity="0"
                IsHitTestVisible="False">
                <!-- Transparent hit target: no Button chrome on hover; only the circle fill shifts slightly. -->
                <Border
                    x:Name="CloseAudienceHitArea"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    AutomationProperties.Name="Close audience output"
                    Background="Transparent"
                    PointerEntered="CloseAudienceHitArea_PointerEntered"
                    PointerExited="CloseAudienceHitArea_PointerExited"
                    Tapped="CloseAudienceHitArea_Tapped"
                    ToolTipService.ToolTip="Close audience output">
                    <Viewbox Width="56" Height="56">
                        <Grid Width="48" Height="48">
                            <!-- Semi-transparent disc + MDL2 ChromeClose (E8BB); circle fill alpha bumps slightly on hover. -->
                            <Ellipse
                                x:Name="CloseCircle"
                                Width="48"
                                Height="48"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Fill="#99FFFFFF" />
                            <FontIcon
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                FontSize="20"
                                Foreground="#FF000000"
                                Glyph="&#xE8BB;"
                                IsHitTestVisible="False" />
                        </Grid>
                    </Viewbox>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
