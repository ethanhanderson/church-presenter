<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="ChurchPresenter.Views.ClearGroupsFlyoutContent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:ChurchPresenter.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:ChurchPresenter.ViewModels"
    MinWidth="640"
    MinHeight="420"
    MaxWidth="760"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>

    <Grid ColumnDefinitions="300,1,*">
        <Border
            Grid.Column="0"
            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
            VerticalAlignment="Stretch">
            <Grid
                Padding="16"
                RowDefinitions="Auto,Auto"
                RowSpacing="10"
                VerticalAlignment="Top">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                    Text="Custom clear groups" />
                <Button
                    Grid.Column="1"
                    Width="32"
                    Height="32"
                    MinWidth="32"
                    MinHeight="32"
                    Padding="0"
                    AutomationProperties.Name="Create clear group"
                    Click="AddClearGroup_Click"
                    ToolTipService.ToolTip="Create a new custom clear group">
                    <FontIcon
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        FontSize="14"
                        Glyph="&#xE710;" />
                </Button>
            </Grid>

            <ListView
                x:Name="ClearGroupsListView"
                Grid.Row="1"
                MinHeight="260"
                MaxHeight="360"
                Padding="0"
                VerticalAlignment="Stretch"
                ItemsSource="{Binding ClearGroups}"
                SelectedItem="{Binding SelectedClearGroup, Mode=TwoWay}"
                ContainerContentChanging="ClearGroupsListView_ContainerContentChanging"
                SelectionChanged="ClearGroupsListView_SelectionChanged"
                SelectionMode="Single">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:ClearGroupSettingsItem">
                        <Grid
                            x:Name="ClearGroupRowRoot"
                            Padding="4,4"
                            ColumnDefinitions="Auto,*"
                            ColumnSpacing="10">
                            <FontIcon
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                FontSize="16"
                                Glyph="{x:Bind Icon, Mode=OneWay}" />
                            <TextBlock
                                Grid.Column="1"
                                Margin="0,0,34,0"
                                VerticalAlignment="Center"
                                Text="{x:Bind Name, Mode=OneWay}"
                                TextTrimming="CharacterEllipsis" />
                            <Button
                                x:Name="DeleteClearGroupButton"
                                Grid.Column="1"
                                Width="28"
                                Height="28"
                                MinWidth="28"
                                MinHeight="28"
                                Padding="0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                AutomationProperties.Name="Delete clear group"
                                Click="DeleteClearGroup_Click"
                                IsHitTestVisible="False"
                                Opacity="0"
                                Tag="{Binding}"
                                ToolTipService.ToolTip="Delete clear group">
                                <FontIcon
                                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                    FontSize="12"
                                    Glyph="&#xE74D;" />
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            </Grid>
        </Border>

        <Border
            Grid.Column="1"
            Background="{ThemeResource CardStrokeColorDefaultBrush}"
            IsHitTestVisible="False" />

        <Grid Grid.Column="2" Padding="16">
            <StackPanel
                Spacing="14"
                Visibility="{Binding HasSelectedClearGroup, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                    Text="Custom group" />

                <Grid ColumnDefinitions="*,160" ColumnSpacing="12" RowDefinitions="Auto,Auto" RowSpacing="10">
                    <StackPanel Grid.Column="0" Grid.Row="0" Spacing="4">
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Text="Name" />
                        <TextBox
                            PlaceholderText="Clear group name"
                            Text="{Binding SelectedClearGroup.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            LostFocus="PersistClearGroups_LostFocus" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Grid.Row="0" Spacing="4">
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Text="Icon" />
                        <ComboBox
                            HorizontalAlignment="Stretch"
                            ItemsSource="{Binding IconOptions}"
                            SelectedValue="{Binding SelectedClearGroup.Icon, Mode=TwoWay}"
                            SelectedValuePath="Glyph"
                            SelectionChanged="PersistClearGroups_SelectionChanged">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:ClearGroupIconOption">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon
                                            FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                            FontSize="14"
                                            Glyph="{x:Bind Glyph}" />
                                        <TextBlock Text="{x:Bind Name}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1" Spacing="8">
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Text="Icon tint" />
                        <ComboBox
                            x:Name="TintComboBox"
                            HorizontalAlignment="Stretch"
                            ItemsSource="{Binding TintOptions}"
                            SelectedValuePath="Color"
                            SelectionChanged="TintComboBox_SelectionChanged">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:ClearGroupTintOption">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Border
                                            Width="14"
                                            Height="14"
                                            VerticalAlignment="Center"
                                            Background="{x:Bind PreviewBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="7" />
                                        <TextBlock Text="{x:Bind Name}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                </Grid>

                <StackPanel Spacing="8">
                    <TextBlock
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                        Text="Layers to clear" />
                    <ItemsControl ItemsSource="{Binding SelectedClearGroup.Scopes}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Spacing="2" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ClearScopeSettingsItem">
                                <CheckBox
                                    Content="{x:Bind DisplayName, Mode=OneWay}"
                                    IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                    Checked="PersistClearGroups_CheckChanged"
                                    Unchecked="PersistClearGroups_CheckChanged" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>

            <StackPanel
                MaxWidth="300"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8"
                Visibility="{Binding HasSelectedClearGroup, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert}">
                <FontIcon
                    HorizontalAlignment="Center"
                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                    FontSize="28"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Glyph="&#xE710;" />
                <TextBlock
                    HorizontalAlignment="Center"
                    FontWeight="SemiBold"
                    Text="Create a clear group"
                    TextAlignment="Center" />
                <TextBlock
                    HorizontalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Use the plus button to define a custom group for the secondary clear buttons bar."
                    TextAlignment="Center"
                    TextWrapping="WrapWholeWords" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
