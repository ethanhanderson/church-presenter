<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="ChurchPresenter.Views.NewPresentationDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:ChurchPresenter.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ChurchPresenter.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="New Presentation"
    PrimaryButtonText="Create"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    PrimaryButtonClick="Dialog_PrimaryButtonClick"
    mc:Ignorable="d">

    <ContentDialog.Resources>
        <DataTemplate x:Key="ThemePickerItemTemplate" x:DataType="local:CreatePresentationThemeChoice">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Border
                    Width="72"
                    Height="40"
                    Background="Black"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="5">
                    <Grid>
                        <controls:SlideStageView
                            IsHitTestVisible="False"
                            Project="{x:Bind PreviewProject, Mode=OneTime}"
                            RenderMode="Thumbnail"
                            Slide="{x:Bind PreviewSlide, Mode=OneTime}"
                            Visibility="{x:Bind ThemePreviewVisibility, Mode=OneTime}" />

                        <Grid Visibility="{x:Bind NoThemePreviewVisibility, Mode=OneTime}">
                            <Grid
                                Background="{ThemeResource LayerFillColorDefaultBrush}"
                                ColumnDefinitions="*,*,*,*,*,*,*,*"
                                RowDefinitions="*,*,*,*">
                                <Rectangle Grid.Row="0" Grid.Column="0" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                <Rectangle Grid.Row="0" Grid.Column="2" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                <Rectangle Grid.Row="0" Grid.Column="4" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                <Rectangle Grid.Row="0" Grid.Column="6" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                <Rectangle Grid.Row="1" Grid.Column="1" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                <Rectangle Grid.Row="1" Grid.Column="3" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                <Rectangle Grid.Row="1" Grid.Column="5" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                <Rectangle Grid.Row="1" Grid.Column="7" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                <Rectangle Grid.Row="2" Grid.Column="0" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                <Rectangle Grid.Row="2" Grid.Column="2" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                <Rectangle Grid.Row="2" Grid.Column="4" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                <Rectangle Grid.Row="2" Grid.Column="6" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                <Rectangle Grid.Row="3" Grid.Column="1" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                <Rectangle Grid.Row="3" Grid.Column="3" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                <Rectangle Grid.Row="3" Grid.Column="5" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                <Rectangle Grid.Row="3" Grid.Column="7" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                            </Grid>
                            <Border
                                Width="24"
                                Height="24"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="12">
                                <FontIcon
                                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Glyph="&#xE711;" />
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <TextBlock
                    VerticalAlignment="Center"
                    FontWeight="SemiBold"
                    Text="{x:Bind Name, Mode=OneTime}"
                    TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </DataTemplate>

        <Style x:Key="ThemeMenuFlyoutItemStyle" TargetType="MenuFlyoutItem">
            <Setter Property="MinWidth" Value="480" />
            <Setter Property="MinHeight" Value="56" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuFlyoutItem">
                        <Grid
                            x:Name="Root"
                            MinHeight="{TemplateBinding MinHeight}"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorTertiaryBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="0.4" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>

                            <ContentControl
                                Width="16"
                                Height="16"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Content="{TemplateBinding Icon}" />

                            <ContentControl
                                Grid.Column="1"
                                Content="{TemplateBinding Tag}"
                                ContentTemplate="{StaticResource ThemePickerItemTemplate}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ContentDialog.Resources>

    <StackPanel
        Width="480"
        HorizontalAlignment="Stretch"
        Spacing="12">

        <StackPanel Spacing="4">
            <TextBlock
                FontWeight="SemiBold"
                Text="Name" />
            <TextBox
                x:Name="NameBox"
                HorizontalAlignment="Stretch"
                PlaceholderText="Presentation name"
                Text="Untitled Presentation" />
        </StackPanel>

        <StackPanel Spacing="4">
            <TextBlock
                FontWeight="SemiBold"
                Text="Theme" />
            <DropDownButton
                x:Name="ThemePickerButton"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Stretch">
                <DropDownButton.Content>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Border
                            Width="72"
                            Height="40"
                            Background="Black"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="5">
                            <Grid>
                                <controls:SlideStageView
                                    x:Name="SelectedThemePreview"
                                    IsHitTestVisible="False"
                                    RenderMode="Thumbnail" />
                                <Grid x:Name="SelectedNoThemePreview">
                                    <Grid
                                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                                        ColumnDefinitions="*,*,*,*,*,*,*,*"
                                        RowDefinitions="*,*,*,*">
                                        <Rectangle Grid.Row="0" Grid.Column="0" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                        <Rectangle Grid.Row="0" Grid.Column="2" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                        <Rectangle Grid.Row="0" Grid.Column="4" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                        <Rectangle Grid.Row="0" Grid.Column="6" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                        <Rectangle Grid.Row="1" Grid.Column="1" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                        <Rectangle Grid.Row="1" Grid.Column="3" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                        <Rectangle Grid.Row="1" Grid.Column="5" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                        <Rectangle Grid.Row="1" Grid.Column="7" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                        <Rectangle Grid.Row="2" Grid.Column="0" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                        <Rectangle Grid.Row="2" Grid.Column="2" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                        <Rectangle Grid.Row="2" Grid.Column="4" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                        <Rectangle Grid.Row="2" Grid.Column="6" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                        <Rectangle Grid.Row="3" Grid.Column="1" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                        <Rectangle Grid.Row="3" Grid.Column="3" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                        <Rectangle Grid.Row="3" Grid.Column="5" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                        <Rectangle Grid.Row="3" Grid.Column="7" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                    </Grid>
                                    <Border
                                        Width="24"
                                        Height="24"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                        <FontIcon
                                            FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                            FontSize="12"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Glyph="&#xE711;" />
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>
                        <TextBlock
                            x:Name="SelectedThemeText"
                            VerticalAlignment="Center"
                            FontWeight="SemiBold"
                            TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </DropDownButton.Content>
                <DropDownButton.Flyout>
                    <MenuFlyout
                        x:Name="ThemePickerMenuFlyout"
                        Placement="BottomEdgeAlignedLeft" />
                </DropDownButton.Flyout>
            </DropDownButton>
        </StackPanel>

        <StackPanel Spacing="4">
            <TextBlock
                FontWeight="SemiBold"
                Text="Size" />
            <DropDownButton
                x:Name="SizePickerButton"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Stretch">
                <DropDownButton.Content>
                    <TextBlock x:Name="SelectedSizeText" />
                </DropDownButton.Content>
                <DropDownButton.Flyout>
                    <MenuFlyout
                        x:Name="SizePickerMenuFlyout"
                        Placement="BottomEdgeAlignedLeft" />
                </DropDownButton.Flyout>
            </DropDownButton>
        </StackPanel>

        <StackPanel Spacing="4">
            <TextBlock
                FontWeight="SemiBold"
                Text="Library" />
            <DropDownButton
                x:Name="LibraryPickerButton"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Stretch">
                <DropDownButton.Content>
                    <TextBlock x:Name="SelectedLibraryText" />
                </DropDownButton.Content>
                <DropDownButton.Flyout>
                    <MenuFlyout
                        x:Name="LibraryPickerMenuFlyout"
                        Placement="BottomEdgeAlignedLeft" />
                </DropDownButton.Flyout>
            </DropDownButton>
        </StackPanel>

        <StackPanel Spacing="4">
            <TextBlock
                FontWeight="SemiBold"
                Text="Playlist" />
            <DropDownButton
                x:Name="PlaylistPickerButton"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Stretch">
                <DropDownButton.Content>
                    <TextBlock x:Name="SelectedPlaylistText" />
                </DropDownButton.Content>
                <DropDownButton.Flyout>
                    <MenuFlyout
                        x:Name="PlaylistPickerMenuFlyout"
                        Placement="BottomEdgeAlignedLeft" />
                </DropDownButton.Flyout>
            </DropDownButton>
        </StackPanel>

        <TextBlock
            x:Name="ValidationText"
            Foreground="{ThemeResource SystemFillColorCriticalBrush}"
            TextWrapping="Wrap"
            Visibility="Collapsed" />
    </StackPanel>
</ContentDialog>
