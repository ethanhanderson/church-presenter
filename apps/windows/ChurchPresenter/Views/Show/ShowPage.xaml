                                                Style="{StaticResource ShowDeckViewModeSegmentButtonStyle}"
                                                ToolTipService.ToolTip="Custom media transition">
                                                <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                                    <Border
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Stretch"
                                                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                        CornerRadius="0,4,4,0"
                                                        Visibility="{x:Bind ViewModel.GlobalMediaTransitionIsCustom, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
                                                    <Grid
                                                        Padding="10,6"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                        <TextBlock
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            FontSize="12"
                                                            Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                            Text="Custom"
                                                            Visibility="{x:Bind ViewModel.GlobalMediaTransitionIsCustom, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert, Mode=OneWay}" />
                                                        <TextBlock
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            FontSize="12"
                                                            Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                                            Text="Custom"
                                                            Visibility="{x:Bind ViewModel.GlobalMediaTransitionIsCustom, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
                                                    </Grid>
                                                </Grid>
                                            </Button>
                                        </Grid>
                                    </Border>
                                    <Grid
                                        VerticalAlignment="Center"
                                        ColumnDefinitions="Auto,Auto"
                                        ColumnSpacing="6"
                                        Visibility="{x:Bind ViewModel.GlobalMediaTransitionIsDissolve, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                                        <Slider
                                            Grid.Column="0"
                                            Width="100"
                                            VerticalAlignment="Center"
                                            Maximum="3000"
                                            Minimum="50"
                                            SnapsTo="StepValues"
                                            StepFrequency="100"
                                            ToolTipService.ToolTip="Media dissolve duration (ms)"
                                            Value="{x:Bind ViewModel.GlobalMediaDissolveDurationMs, Mode=TwoWay}" />
                                        <TextBlock
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            MinWidth="40"
                                            FontSize="11"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="{x:Bind ViewModel.GlobalMediaDissolveDurationMs, Mode=OneWay, Converter={StaticResource MsToSecondsLabelConverter}}"
                                            TextLineBounds="Tight" />
                                    </Grid>
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        MaxWidth="260"
                                        FontSize="11"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{x:Bind ViewModel.GlobalMediaCustomTransitionToolbarLabel, Mode=OneWay}"
                                        TextTrimming="CharacterEllipsis"
                                        ToolTipService.ToolTip="{x:Bind ViewModel.GlobalMediaCustomTransitionToolbarLabel, Mode=OneWay}"
                                        Visibility="{x:Bind ViewModel.GlobalMediaTransitionIsCustom, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
                                </StackPanel>
                                <StackPanel
                                    Grid.Column="2"
                                    HorizontalAlignment="Right"
                                    Orientation="Horizontal"
                                    Spacing="4">
                                    <Border
                                        MinHeight="30"
                                        VerticalAlignment="Center"
                                        Background="{ThemeResource ControlFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4">
                                        <Grid ColumnDefinitions="*,Auto,*">
                                            <Button
                                                x:Name="MediaLayoutGridButton"
                                                Grid.Column="0"
                                                AutomationProperties.Name="Grid view"
                                                Click="MediaPanelLayoutGrid_Click"
                                                CornerRadius="4,0,0,4"
                                                Style="{StaticResource ShowDeckViewModeSegmentButtonStyle}"
                                                ToolTipService.ToolTip="Grid view">
                                                <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                                    <Border
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Stretch"
                                                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                        CornerRadius="4,0,0,4"
                                                        Visibility="{x:Bind ViewModel.MediaPanelIsGridMode, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
                                                    <Grid
                                                        Padding="10,8"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                        <FontIcon
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                            FontSize="14"
                                                            Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                            Glyph="&#xF0E2;"
                                                            Visibility="{x:Bind ViewModel.MediaPanelIsGridMode, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert, Mode=OneWay}" />
                                                        <FontIcon
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                            FontSize="14"
                                                            Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                                            Glyph="&#xF0E2;"
                                                            Visibility="{x:Bind ViewModel.MediaPanelIsGridMode, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
                                                    </Grid>
                                                </Grid>
                                            </Button>
                                            <Border
                                                Grid.Column="1"
                                                Width="1"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Stretch"
                                                Background="{ThemeResource CardStrokeColorDefaultBrush}" />
                                            <Button
                                                x:Name="MediaLayoutListButton"
                                                Grid.Column="2"
                                                AutomationProperties.Name="List view"
                                                Click="MediaPanelLayoutList_Click"
                                                CornerRadius="0,4,4,0"
                                                Style="{StaticResource ShowDeckViewModeSegmentButtonStyle}"
                                                ToolTipService.ToolTip="List view">
                                                <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                                    <Border
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Stretch"
                                                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                        CornerRadius="0,4,4,0"
                                                        Visibility="{x:Bind ViewModel.MediaPanelIsListMode, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
                                                    <Grid
                                                        Padding="10,8"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                        <FontIcon
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                            FontSize="14"
                                                            Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                            Glyph="&#xE8FD;"
                                                            Visibility="{x:Bind ViewModel.MediaPanelIsListMode, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert, Mode=OneWay}" />
                                                        <FontIcon
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                            FontSize="14"
                                                            Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                                            Glyph="&#xE8FD;"
                                                            Visibility="{x:Bind ViewModel.MediaPanelIsListMode, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
                                                    </Grid>
                                                </Grid>
                                            </Button>
                                        </Grid>
                                    </Border>
                                    <Border
                                        Width="1"
                                        Height="18"
                                        Margin="2,0,2,0"
                                        VerticalAlignment="Center"
                                        Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                                    <Slider
                                        x:Name="MediaPanelScaleSlider"
                                        Width="120"
                                        VerticalAlignment="Center"
                                        AutomationProperties.Name="Media thumbnail size"
                                        Maximum="7"
                                        Minimum="0"
                                        SnapsTo="StepValues"
                                        StepFrequency="1"
                                        TickFrequency="1"
                                        TickPlacement="None"
                                        ToolTipService.ToolTip="Thumbnail size (grid and table)"
                                        Value="{x:Bind ViewModel.MediaPanelScaleStep, Mode=OneWay}"
                                        ValueChanged="MediaPanelScaleSlider_ValueChanged" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
                <Border
                    x:Name="MediaPanelResizeHandle"
                    Height="10"
                    Margin="0,-5,0,0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Top"
                    Background="Transparent"
                    PointerEntered="MediaPanelSplitter_PointerEntered"
                    PointerExited="MediaPanelSplitter_PointerExited"
                    PointerPressed="MediaPanelSplitter_PointerPressed"
                    PointerMoved="MediaPanelSplitter_PointerMoved"
                    PointerReleased="MediaPanelSplitter_PointerReleased"
                    PointerCaptureLost="MediaPanelSplitter_PointerCaptureLost">
                    <Border
                        x:Name="MediaPanelResizeHandleHoverLine"
                        Height="2"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center"
                        Background="{ThemeResource ShowOutputPanelResizeHoverBrush}"
                        Opacity="0">
                        <Border.OpacityTransition>
                            <ScalarTransition Duration="0:0:0.12" />
                        </Border.OpacityTransition>
                    </Border>
                </Border>
            </Grid>
        </Border>

        <!-- Output column: left hairline only, full content height; padding insets the preview card. -->
        <Border
            x:Name="OutputPanelChromeBorder"
            Grid.Column="1"
            Grid.Row="0"
            Grid.RowSpan="2"
            MinHeight="0"
            VerticalAlignment="Stretch"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1,1,0,0"
            Padding="16,14,20,16">
                    <Grid
                        MinHeight="0"
                        VerticalAlignment="Stretch"
                        RowDefinitions="Auto,Auto,*">
                        <Border
                            x:Name="OutputPreviewAndClearBarsCard"
                            Margin="0"
                            VerticalAlignment="Top"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Background="{ThemeResource ShowOutputPreviewCardAcrylicBrush}">
                            <Grid
                                x:Name="OutputPreviewAndClearBarsContainer"
                                Loaded="OutputPreviewAndClearBarsContainer_Loaded"
                                RowDefinitions="Auto,Auto,Auto,Auto"
                                SizeChanged="OutputPreviewAndClearBarsContainer_SizeChanged"
                                Unloaded="OutputPreviewAndClearBarsContainer_Unloaded">
                                <Border
                                    Grid.Row="0"
                                    VerticalAlignment="Top"
                                    UseLayoutRounding="True"
                                    Background="Black"
                                    CornerRadius="0">
                                    <local:ProgramOutputSurface
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        PlaybackRegistrationMode="Authority"
                                        ViewModel="{x:Bind ViewModel.ProgramOutput, Mode=OneWay}" />
                                </Border>
                                <Border
                                    x:Name="SecondaryOutputClearCommandBar"
                                    Grid.Row="1"
                                    Height="44"
                                    Margin="0"
                                    Background="{ThemeResource ShowOutputToolbarAcrylicBrush}"
                                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                    BorderThickness="0,1,0,0"
                                    Visibility="{x:Bind ViewModel.HasSecondaryOutputClearActions, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"
                                    RightTapped="SecondaryOutputClearCommandBar_RightTapped">
                                    <Grid
                                        Margin="0"
                                        Padding="0"
                                        ColumnDefinitions="*,Auto">
                                            <ItemsControl
                                                Grid.Column="0"
                                                Margin="0"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Stretch"
                                                ItemsSource="{x:Bind ViewModel.SecondaryOutputClearActions, Mode=OneWay}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <controls:EqualColumnsPanel MinimumColumnWidth="64" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemContainerStyle>
                                                    <Style TargetType="ContentPresenter">
                                                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                                                        <Setter Property="VerticalAlignment" Value="Stretch" />
                                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                        <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                                    </Style>
                                                </ItemsControl.ItemContainerStyle>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:ShowClearActionViewModel">
                                                        <Grid
                                                            Margin="0"
                                                            Background="Transparent"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Stretch"
                                                            ToolTipService.ToolTip="{x:Bind Label, Mode=OneWay}">
                                                            <AppBarButton
                                                                Style="{StaticResource ShowOutputClearTintedAppBarButtonStyle}"
                                                                Margin="0"
                                                                HorizontalAlignment="Stretch"
                                                                VerticalAlignment="Stretch"
                                                                Background="{x:Bind ButtonBackgroundBrush, Mode=OneWay}"
                                                                Command="{x:Bind ExecuteCommand, Mode=OneWay}"
                                                                CommandParameter="{Binding}"
                                                                IsCompact="True"
                                                                Label="{x:Bind Label, Mode=OneWay}"
                                                                MinHeight="0"
                                                                MinWidth="0"
                                                                AutomationProperties.AutomationId="{x:Bind Id, Mode=OneWay}"
                                                                AutomationProperties.Name="{x:Bind Label, Mode=OneWay}">
                                                                <AppBarButton.Icon>
                                                                    <FontIcon
                                                                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                                        Glyph="{x:Bind IconGlyph, Mode=OneWay}" />
                                                                </AppBarButton.Icon>
                                                            </AppBarButton>
                                                            <Line
                                                                Width="1"
                                                                X1="0"
                                                                Y1="0"
                                                                X2="0"
                                                                Y2="1"
                                                                HorizontalAlignment="Left"
                                                                VerticalAlignment="Stretch"
                                                                IsHitTestVisible="False"
                                                                Stroke="{ThemeResource DividerStrokeColorDefaultBrush}"
                                                                StrokeThickness="1"
                                                                Stretch="Fill"
                                                                Visibility="{x:Bind HasLeadingDivider, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                    </Grid>
                                </Border>

                                <Border
                                    x:Name="PrimaryOutputClearCommandBar"
                                    Grid.Row="3"
                                    Height="48"
                                    Margin="0"
                                    Background="{ThemeResource ShowOutputToolbarAcrylicBrush}"
                                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                    BorderThickness="0,1,0,0"
                                    CornerRadius="0"
                                    RightTapped="PrimaryOutputClearCommandBar_RightTapped">
                                    <Grid
                                        Margin="0"
                                        Padding="0">
                                            <ItemsControl
                                                Margin="0"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Stretch"
                                                ItemsSource="{x:Bind ViewModel.PrimaryOutputClearActions, Mode=OneWay}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <controls:EqualColumnsPanel MinimumColumnWidth="64" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemContainerStyle>
                                                    <Style TargetType="ContentPresenter">
                                                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                                                        <Setter Property="VerticalAlignment" Value="Stretch" />
                                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                        <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                                    </Style>
                                                </ItemsControl.ItemContainerStyle>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:ShowClearActionViewModel">
                                                        <Grid
                                                            Margin="0"
                                                            Background="Transparent"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Stretch"
                                                            ToolTipService.ToolTip="{x:Bind Label, Mode=OneWay}">
                                                            <AppBarButton
                                                                Style="{StaticResource ShowOutputClearAppBarButtonStyle}"
                                                                Margin="0"
                                                                HorizontalAlignment="Stretch"
                                                                VerticalAlignment="Stretch"
                                                                Command="{x:Bind ExecuteCommand, Mode=OneWay}"
                                                                CommandParameter="{Binding}"
                                                                IsCompact="True"
                                                                Label="{x:Bind Label, Mode=OneWay}"
                                                                MinHeight="0"
                                                                MinWidth="0"
                                                                Visibility="{x:Bind IsActive, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert, Mode=OneWay}"
                                                                AutomationProperties.AutomationId="{x:Bind Id, Mode=OneWay}"
                                                                AutomationProperties.Name="{x:Bind Label, Mode=OneWay}">
                                                                <AppBarButton.Icon>
                                                                    <FontIcon
                                                                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                                        Glyph="{x:Bind IconGlyph, Mode=OneWay}" />
                                                                </AppBarButton.Icon>
                                                            </AppBarButton>
                                                            <AppBarButton
                                                                Style="{StaticResource ShowOutputClearPrimaryAppBarButtonStyle}"
                                                                Margin="0"
                                                                HorizontalAlignment="Stretch"
                                                                VerticalAlignment="Stretch"
                                                                Command="{x:Bind ExecuteCommand, Mode=OneWay}"
                                                                CommandParameter="{Binding}"
                                                                IsCompact="True"
                                                                Label="{x:Bind Label, Mode=OneWay}"
                                                                MinHeight="0"
                                                                MinWidth="0"
                                                                Visibility="{x:Bind IsActive, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"
                                                                AutomationProperties.AutomationId="{x:Bind Id, Mode=OneWay}"
                                                                AutomationProperties.Name="{x:Bind Label, Mode=OneWay}">
                                                                <AppBarButton.Icon>
                                                                    <FontIcon
                                                                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                                        Glyph="{x:Bind IconGlyph, Mode=OneWay}" />
                                                                </AppBarButton.Icon>
                                                            </AppBarButton>
                                                            <Border
                                                                Width="26"
                                                                Height="24"
                                                                Margin="0,4,0,0"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Top"
                                                                Background="{x:Bind IconBackgroundBrush, Mode=OneWay}"
                                                                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="5"
                                                                IsHitTestVisible="False"
                                                                Visibility="{x:Bind TintEnabled, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                                                                <FontIcon
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                                    FontSize="13"
                                                                    Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                                                    Glyph="{x:Bind IconGlyph, Mode=OneWay}" />
                                                            </Border>
                                                            <Line
                                                                Width="1"
                                                                X1="0"
                                                                Y1="0"
                                                                X2="0"
                                                                Y2="1"
                                                                HorizontalAlignment="Left"
                                                                VerticalAlignment="Stretch"
                                                                IsHitTestVisible="False"
                                                                Stroke="{ThemeResource DividerStrokeColorDefaultBrush}"
                                                                StrokeThickness="1"
                                                                Stretch="Fill"
                                                                Visibility="{x:Bind HasLeadingDivider, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                    </Grid>
                                </Border>

                            </Grid>
                        </Border>

                        <!-- Row 1: media transport controls -->
                        <Border
                            x:Name="MediaTransportCardContainer"
                            Grid.Row="1"
                            Margin="0,12,0,0"
                            Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Loaded="MediaTransportCardContainer_Loaded"
                            SizeChanged="MediaTransportCardContainer_SizeChanged"
                            Unloaded="MediaTransportCardContainer_Unloaded">
                            <Grid RowDefinitions="Auto,Auto">
                            <Border
                                Grid.Row="0"
                                Padding="6,4"
                                HorizontalAlignment="Stretch"
                                Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                BorderThickness="0,0,0,1"
                                CornerRadius="0">
                                <SelectorBar
                                    x:Name="MediaTransportTargetSelectorBar"
                                    HorizontalAlignment="Center"
                                    AutomationProperties.AutomationId="MediaTransportTargetSelectorBar"
                                    SelectionChanged="MediaTransportTargetSelectorBar_SelectionChanged">
                                    <SelectorBarItem
                                        x:Name="MediaFilesTransportSelectorItem"
                                        MinWidth="52"
                                        MinHeight="36"
                                        AutomationProperties.AutomationId="MediaFilesTransportSelectorItem"
                                        AutomationProperties.Name="Media files"
                                        Tag="MediaFiles"
                                        ToolTipService.ToolTip="Media Files">
                                        <SelectorBarItem.Icon>
                                            <FontIcon
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                FontSize="16"
                                                Glyph="&#xE714;" />
                                        </SelectorBarItem.Icon>
                                    </SelectorBarItem>
                                    <SelectorBarItem
                                        x:Name="AudioFilesTransportSelectorItem"
                                        MinWidth="52"
                                        MinHeight="36"
                                        AutomationProperties.AutomationId="AudioFilesTransportSelectorItem"
                                        AutomationProperties.Name="Audio files"
                                        Tag="AudioFiles"
                                        ToolTipService.ToolTip="Audio Files">
                                        <SelectorBarItem.Icon>
                                            <FontIcon
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                FontSize="16"
                                                Glyph="&#xE8D6;" />
                                        </SelectorBarItem.Icon>
                                    </SelectorBarItem>
                                    <SelectorBarItem
                                        x:Name="AnnouncementsTransportSelectorItem"
                                        MinWidth="52"
                                        MinHeight="36"
                                        AutomationProperties.AutomationId="AnnouncementsTransportSelectorItem"
                                        AutomationProperties.Name="Announcements"
                                        Tag="Announcements"
                                        ToolTipService.ToolTip="Announcements">
                                        <SelectorBarItem.Icon>
                                            <FontIcon
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                FontSize="16"
                                                Glyph="&#xE789;" />
                                        </SelectorBarItem.Icon>
                                    </SelectorBarItem>
                                </SelectorBar>
                            </Border>

                            <Border
                                Grid.Row="1"
                                Padding="12"
                                Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                                BorderThickness="0"
                                CornerRadius="0"
                                Visibility="Visible">
                            <Grid
                                RowDefinitions="Auto,Auto"
                                RowSpacing="14">
                                <!-- Progress and media name -->
                                <Grid
                                    Grid.Row="0"
                                    RowDefinitions="Auto,Auto"
                                    RowSpacing="2">
                                    <Slider
                                        x:Name="MediaTransportSeekSlider"
                                        Grid.Row="0"
                                        Margin="0"
                                        VerticalAlignment="Center"
                                        Minimum="0"
                                        Maximum="{x:Bind ViewModel.PlaybackCoordinator.TransportSliderMaximum, Mode=OneWay}"
                                        Value="{x:Bind ViewModel.PlaybackCoordinator.TransportSliderValue, Mode=OneWay}"
                                        IsEnabled="{x:Bind ViewModel.PlaybackCoordinator.HasActiveCue, Mode=OneWay}"
                                        IsThumbToolTipEnabled="False"
                                        Loaded="MediaTransportSeekSlider_Loaded"
                                        Unloaded="MediaTransportSeekSlider_Unloaded"
                                        PointerReleased="MediaTransportSeek_PointerReleased"
                                        PointerCaptureLost="MediaTransportSeek_PointerCaptureLost"
                                        ValueChanged="MediaTransportSeek_ValueChanged"
                                        ThumbToolTipValueConverter="{x:Null}" />

                                    <Grid
                                        Grid.Row="1"
                                        MinHeight="20"
                                        ColumnDefinitions="Auto,*,Auto"
                                        ColumnSpacing="8">
                                        <TextBlock
                                            Grid.Column="0"
                                            MinWidth="36"
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            HorizontalTextAlignment="Left"
                                            Text="{x:Bind ViewModel.PlaybackCoordinator.TransportPositionLabel, Mode=OneWay}" />
                                        <TextBlock
                                            Grid.Column="1"
                                            MinWidth="0"
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            HorizontalTextAlignment="Center"
                                            Text="{x:Bind ViewModel.PlaybackCoordinator.TransportCueName, Mode=OneWay}"
                                            TextTrimming="CharacterEllipsis"
                                            TextWrapping="NoWrap" />
                                        <TextBlock
                                            Grid.Column="2"
                                            MinWidth="36"
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                            HorizontalTextAlignment="Right"
                                            Text="{x:Bind ViewModel.PlaybackCoordinator.TransportRemainingLabel, Mode=OneWay}" />
                                    </Grid>
                                </Grid>

                                <!-- Transport controls -->
                                <Grid
                                    Grid.Row="1"
                                    HorizontalAlignment="Center"
                                    ColumnDefinitions="Auto,Auto,Auto,Auto"
                                    ColumnSpacing="8">
                                    <!-- Seek back -->
                                    <Button
                                        Grid.Column="0"
                                        Width="36"
                                        Height="36"
                                        Padding="0"
                                        AutomationProperties.Name="Seek backward"
                                        Command="{x:Bind ViewModel.MediaSeekBackwardCommand, Mode=OneWay}"
                                        IsEnabled="{x:Bind ViewModel.PlaybackCoordinator.HasActiveCue, Mode=OneWay}"
                                        Style="{StaticResource SubtleButtonStyle}"
                                        ToolTipService.ToolTip="Seek backward">
                                        <FontIcon
                                            FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                            FontSize="15"
                                            Glyph="&#xEB9E;" />
                                    </Button>
                                    <!-- Play / Pause -->
                                    <Button
                                        Grid.Column="1"
                                        Width="44"
                                        Height="44"
                                        Padding="0"
                                        AutomationProperties.Name="Play / Pause"
                                        Command="{x:Bind ViewModel.MediaTogglePlayPauseCommand, Mode=OneWay}"
                                        IsEnabled="{x:Bind ViewModel.PlaybackCoordinator.HasActiveCue, Mode=OneWay}"
                                        Style="{StaticResource AccentButtonStyle}"
                                        ToolTipService.ToolTip="Play / Pause">
                                        <FontIcon
                                            FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                            FontSize="17"
                                            Glyph="{x:Bind ViewModel.PlaybackCoordinator.IsPlaying, Converter={StaticResource BoolToPlayPauseGlyphConverter}, Mode=OneWay}" />
                                    </Button>
                                    <!-- Seek forward -->
                                    <Button
                                        Grid.Column="2"
                                        Width="36"
                                        Height="36"
                                        Padding="0"
                                        AutomationProperties.Name="Seek forward"
                                        Command="{x:Bind ViewModel.MediaSeekForwardCommand, Mode=OneWay}"
                                        IsEnabled="{x:Bind ViewModel.PlaybackCoordinator.HasActiveCue, Mode=OneWay}"
                                        Style="{StaticResource SubtleButtonStyle}"
                                        ToolTipService.ToolTip="Seek forward">
                                        <FontIcon
                                            FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                            FontSize="15"
                                            Glyph="&#xEB9D;" />
                                    </Button>
                                    <!-- Restart -->
                                    <Button
                                        Grid.Column="3"
                                        Width="36"
                                        Height="36"
                                        Padding="0"
                                        AutomationProperties.Name="Restart"
                                        Command="{x:Bind ViewModel.MediaRestartCommand, Mode=OneWay}"
                                        IsEnabled="{x:Bind ViewModel.PlaybackCoordinator.HasActiveCue, Mode=OneWay}"
                                        Style="{StaticResource SubtleButtonStyle}"
                                        ToolTipService.ToolTip="Restart">
                                        <FontIcon
                                            FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                            FontSize="15"
                                            Glyph="&#xE72C;" />
                                    </Button>
                                </Grid>
                            </Grid>
                            </Border>
                            </Grid>
                        </Border>

                        <Border
                            x:Name="ShowControlsCardContainer"
                            Grid.Row="2"
                            MinHeight="260"
                            Margin="0,12,0,0"
                            Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Grid RowDefinitions="Auto,*">
                                <Border
                                    Grid.Row="0"
                                    Padding="6,4"
                                    Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                    BorderThickness="0,0,0,1">
                                    <SelectorBar
                                        x:Name="ShowControlsSelectorBar"
                                        HorizontalAlignment="Center"
                                        AutomationProperties.AutomationId="ShowControlsSelectorBar"
                                        SelectionChanged="ShowControlsSelectorBar_SelectionChanged">
                                        <SelectorBarItem x:Name="AudioBinSelectorItem" MinHeight="36" MinWidth="48" AutomationProperties.Name="Audio Bin" Tag="audio" ToolTipService.ToolTip="Audio Bin">
                                            <SelectorBarItem.Icon><FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE8D6;" /></SelectorBarItem.Icon>
                                        </SelectorBarItem>
                                        <SelectorBarItem x:Name="StageScreensSelectorItem" MinHeight="36" MinWidth="48" AutomationProperties.Name="Stage Screens" Tag="stage" ToolTipService.ToolTip="Stage Screens">
                                            <SelectorBarItem.Icon><FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE7F4;" /></SelectorBarItem.Icon>
                                        </SelectorBarItem>
                                        <SelectorBarItem x:Name="TimersSelectorItem" MinHeight="36" MinWidth="48" AutomationProperties.Name="Timers" Tag="timers" ToolTipService.ToolTip="Timers">
                                            <SelectorBarItem.Icon><FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE823;" /></SelectorBarItem.Icon>
                                        </SelectorBarItem>
                                        <SelectorBarItem x:Name="MessagesSelectorItem" MinHeight="36" MinWidth="48" AutomationProperties.Name="Messages" Tag="messages" ToolTipService.ToolTip="Messages">
                                            <SelectorBarItem.Icon><FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE724;" /></SelectorBarItem.Icon>
                                        </SelectorBarItem>
                                        <SelectorBarItem x:Name="PropsSelectorItem" MinHeight="36" MinWidth="48" AutomationProperties.Name="Props" Tag="props" ToolTipService.ToolTip="Props">
                                            <SelectorBarItem.Icon><FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE7C3;" /></SelectorBarItem.Icon>
                                        </SelectorBarItem>
                                        <SelectorBarItem x:Name="MacrosSelectorItem" MinHeight="36" MinWidth="48" AutomationProperties.Name="Macros" Tag="macros" ToolTipService.ToolTip="Macros">
                                            <SelectorBarItem.Icon><FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE756;" /></SelectorBarItem.Icon>
                                        </SelectorBarItem>
                                    </SelectorBar>
                                </Border>

                                <ScrollViewer Grid.Row="1" Padding="12" HorizontalScrollBarVisibility="Disabled" HorizontalScrollMode="Disabled" VerticalScrollBarVisibility="Auto" VerticalScrollMode="Auto">
                                    <Grid>
                                        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="10" Visibility="{x:Bind ViewModel.ShowControlsAudioSelected, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                                            <TextBlock FontWeight="SemiBold" Text="Audio Bin" />
                                            <ListView Grid.Row="1" MinHeight="120" ItemsSource="{x:Bind ViewModel.ShowAudioItems, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedAudioCue, Mode=TwoWay}" DisplayMemberPath="Name" />
                                            <StackPanel Grid.Row="2" HorizontalAlignment="Right" Orientation="Horizontal" Spacing="8">
                                                <Button Command="{x:Bind ViewModel.CreateAudioPlaylistCommand, Mode=OneWay}" Content="New Playlist" />
                                                <Button Command="{x:Bind ViewModel.TriggerSelectedAudioCueCommand, Mode=OneWay}" Content="Play Audio" IsEnabled="{x:Bind ViewModel.HasSelectedAudioCue, Mode=OneWay}" Style="{StaticResource AccentButtonStyle}" />
                                            </StackPanel>
                                        </Grid>

                                        <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10" Visibility="{x:Bind ViewModel.ShowControlsStageSelected, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                                            <TextBlock FontWeight="SemiBold" Text="Stage Screens" />
                                            <ListView Grid.Row="1" MaxHeight="110" ItemsSource="{x:Bind ViewModel.ShowStageScreens, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedStageScreen, Mode=TwoWay}" DisplayMemberPath="Name" />
                                            <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                <ComboBox DisplayMemberPath="Name" HorizontalAlignment="Stretch" ItemsSource="{x:Bind ViewModel.ShowStageLayouts, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedStageLayout, Mode=TwoWay}" />
                                                <Button Grid.Column="1" Command="{x:Bind ViewModel.AssignSelectedStageLayoutCommand, Mode=OneWay}" Content="Apply" IsEnabled="{x:Bind ViewModel.HasSelectedStageAssignment, Mode=OneWay}" />
                                            </Grid>
                                            <Grid Grid.Row="3" RowDefinitions="Auto,Auto" RowSpacing="8">
                                                <TextBox Header="Stage message" PlaceholderText="Type a private stage message" Text="{x:Bind ViewModel.StageMessageText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <StackPanel Grid.Row="1" HorizontalAlignment="Right" Orientation="Horizontal" Spacing="8">
                                                    <Button Command="{x:Bind ViewModel.HideStageMessageCommand, Mode=OneWay}" Content="Hide" />
                                                    <Button Command="{x:Bind ViewModel.ShowStageMessageCommand, Mode=OneWay}" Content="Show" Style="{StaticResource AccentButtonStyle}" />
                                                </StackPanel>
                                            </Grid>
                                        </Grid>

                                        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="10" Visibility="{x:Bind ViewModel.ShowControlsTimersSelected, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                                            <TextBlock FontWeight="SemiBold" Text="Timers" />
                                            <ListView Grid.Row="1" MinHeight="120" ItemsSource="{x:Bind ViewModel.ShowTimers, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedTimer, Mode=TwoWay}" DisplayMemberPath="Name" />
                                            <StackPanel Grid.Row="2" HorizontalAlignment="Right" Orientation="Horizontal" Spacing="8">
                                                <Button Command="{x:Bind ViewModel.CreateTimerCommand, Mode=OneWay}" Content="New" />
                                                <Button Command="{x:Bind ViewModel.ResetSelectedTimerCommand, Mode=OneWay}" Content="Reset" IsEnabled="{x:Bind ViewModel.HasSelectedTimer, Mode=OneWay}" />
                                                <Button Command="{x:Bind ViewModel.StopSelectedTimerCommand, Mode=OneWay}" Content="Stop" IsEnabled="{x:Bind ViewModel.HasSelectedTimer, Mode=OneWay}" />
                                                <Button Command="{x:Bind ViewModel.StartSelectedTimerCommand, Mode=OneWay}" Content="Start" IsEnabled="{x:Bind ViewModel.HasSelectedTimer, Mode=OneWay}" Style="{StaticResource AccentButtonStyle}" />
                                            </StackPanel>
                                        </Grid>

                                        <Grid RowDefinitions="Auto,*,Auto,Auto" RowSpacing="10" Visibility="{x:Bind ViewModel.ShowControlsMessagesSelected, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                                            <TextBlock FontWeight="SemiBold" Text="Messages" />
                                            <ListView Grid.Row="1" MinHeight="100" ItemsSource="{x:Bind ViewModel.ShowMessages, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedMessage, Mode=TwoWay}" DisplayMemberPath="Name" />
                                            <TextBox Grid.Row="2" Header="Runtime text / first token" Text="{x:Bind ViewModel.MessageRuntimeText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" />
                                            <StackPanel Grid.Row="3" HorizontalAlignment="Right" Orientation="Horizontal" Spacing="8">
                                                <Button Command="{x:Bind ViewModel.CreateMessageCommand, Mode=OneWay}" Content="New" />
                                                <Button Command="{x:Bind ViewModel.HideSelectedMessageCommand, Mode=OneWay}" Content="Hide" IsEnabled="{x:Bind ViewModel.HasSelectedMessage, Mode=OneWay}" />
                                                <Button Command="{x:Bind ViewModel.ShowSelectedMessageCommand, Mode=OneWay}" Content="Show" IsEnabled="{x:Bind ViewModel.HasSelectedMessage, Mode=OneWay}" Style="{StaticResource AccentButtonStyle}" />
                                            </StackPanel>
                                        </Grid>

                                        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="10" Visibility="{x:Bind ViewModel.ShowControlsPropsSelected, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                                            <TextBlock FontWeight="SemiBold" Text="Props" />
                                            <GridView Grid.Row="1" MinHeight="120" ItemsSource="{x:Bind ViewModel.ShowProps, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedProp, Mode=TwoWay}" DisplayMemberPath="Name" />
                                            <StackPanel Grid.Row="2" HorizontalAlignment="Right" Orientation="Horizontal" Spacing="8">
                                                <Button Command="{x:Bind ViewModel.CreatePropCommand, Mode=OneWay}" Content="New Prop" />
                                                <Button Command="{x:Bind ViewModel.ToggleSelectedPropCommand, Mode=OneWay}" Content="Toggle Prop" IsEnabled="{x:Bind ViewModel.HasSelectedProp, Mode=OneWay}" Style="{StaticResource AccentButtonStyle}" />
                                            </StackPanel>
                                        </Grid>

                                        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="10" Visibility="{x:Bind ViewModel.ShowControlsMacrosSelected, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                                            <TextBlock FontWeight="SemiBold" Text="Macros" />
                                            <GridView Grid.Row="1" MinHeight="120" ItemsSource="{x:Bind ViewModel.ShowMacros, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedMacro, Mode=TwoWay}" DisplayMemberPath="Name" />
                                            <StackPanel Grid.Row="2" HorizontalAlignment="Right" Orientation="Horizontal" Spacing="8">
                                                <Button Command="{x:Bind ViewModel.CreateMacroCommand, Mode=OneWay}" Content="New Macro" />
                                                <Button Command="{x:Bind ViewModel.ExecuteSelectedMacroCommand, Mode=OneWay}" Content="Run Macro" IsEnabled="{x:Bind ViewModel.HasSelectedMacro, Mode=OneWay}" Style="{StaticResource AccentButtonStyle}" />
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

        <!-- East-west resize: same pattern as the media drawer handle (transparent hit target + hover line). -->
        <Border
            x:Name="OutputPanelResizeHandle"
            Grid.Column="1"
            Grid.Row="0"
            Grid.RowSpan="2"
            Width="10"
            Margin="-5,0,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Stretch"
            Background="Transparent"
            AutomationProperties.Name="Resize output preview"
            PointerEntered="OutputPanelResize_PointerEntered"
            PointerExited="OutputPanelResize_PointerExited"
            PointerPressed="OutputPanelResize_PointerPressed"
            PointerMoved="OutputPanelResize_PointerMoved"
            PointerReleased="OutputPanelResize_PointerReleased"
            PointerCaptureLost="OutputPanelResize_PointerCaptureLost"
            DoubleTapped="OutputPanelResize_DoubleTapped">
            <Border
                x:Name="OutputPanelResizeHandleHoverLine"
                Width="2"
                HorizontalAlignment="Center"
                VerticalAlignment="Stretch"
                Background="{ThemeResource ShowOutputPanelResizeHoverBrush}"
                Opacity="0">
                <Border.OpacityTransition>
                    <ScalarTransition Duration="0:0:0.12" />
                </Border.OpacityTransition>
            </Border>
        </Border>

        <Grid
            x:Name="ExportRenderHost"
            Width="1"
            Height="1"
            Margin="-20000,0,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            IsHitTestVisible="False" />

        <!-- Off-screen render host for media drag preview: must be large enough that the card is not clipped (RTB captures layout bounds). -->
        <Grid
            x:Name="MediaDragPreviewHost"
            Width="480"
            Height="420"
            Margin="-20000,0,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            IsHitTestVisible="False" />

        <!-- Off-screen render host for sidebar presentation drag previews. -->
        <Grid
            x:Name="PresentationDragPreviewHost"
            Width="320"
            Height="160"
            Margin="-20000,0,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            IsHitTestVisible="False" />
    </Grid>
</Page>
