<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ChurchPresenter.Views.ShowPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:ChurchPresenter.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:ChurchPresenter.Converters"
    xmlns:local="using:ChurchPresenter.Views"
    xmlns:vm="using:ChurchPresenter.ViewModels"
    xmlns:models="using:ChurchPresenter.Models.Media"
    xmlns:showmodels="using:ChurchPresenter.Models.Show"
    xmlns:windowsui="using:Windows.UI"
    x:Name="RootPage"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <ResourceDictionary>
            <!-- Hairline scrims: low-alpha tints over whatever is behind (acrylic/layer), not opaque fog. -->
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Default">
                    <SolidColorBrush x:Key="ShowChromeDividerBrush" Color="#1A000000" />
                    <SolidColorBrush x:Key="ShowOutputPanelResizeHoverBrush" Color="#66000000" />
                    <SolidColorBrush x:Key="ShowPanelActiveBorderBrush" Color="#40000000" />
                    <SolidColorBrush x:Key="ShowSlideDeckLiveOutlineBrush" Color="#FF22C55E" />
                    <windowsui:Color x:Key="ShowLayerAcrylicTintColor">#FFFFFFFF</windowsui:Color>
                    <windowsui:Color x:Key="ShowLayerAcrylicFallbackColor">#FFEDEDED</windowsui:Color>
                    <windowsui:Color x:Key="ShowCardAcrylicTintColor">#FFFFFFFF</windowsui:Color>
                    <windowsui:Color x:Key="ShowCardAcrylicFallbackColor">#FFF2F2F2</windowsui:Color>
                    <AcrylicBrush
                        x:Key="ShowBrowseDeckHeaderAcrylicBrush"
                        FallbackColor="{StaticResource ShowLayerAcrylicFallbackColor}"
                        TintColor="{StaticResource ShowLayerAcrylicTintColor}"
                        TintLuminosityOpacity="0.88"
                        TintOpacity="0.78" />
                    <AcrylicBrush
                        x:Key="ShowOutputPreviewCardAcrylicBrush"
                        FallbackColor="{StaticResource ShowCardAcrylicFallbackColor}"
                        TintColor="{StaticResource ShowCardAcrylicTintColor}"
                        TintLuminosityOpacity="0.9"
                        TintOpacity="0.82" />
                    <AcrylicBrush
                        x:Key="ShowMediaCardBackgroundAcrylicBrush"
                        FallbackColor="{StaticResource ShowCardAcrylicFallbackColor}"
                        TintColor="{StaticResource ShowCardAcrylicTintColor}"
                        TintLuminosityOpacity="0.92"
                        TintOpacity="0.88" />
                    <AcrylicBrush
                        x:Key="ShowMediaCardBorderAcrylicBrush"
                        FallbackColor="#33000000"
                        TintColor="{StaticResource ShowCardAcrylicTintColor}"
                        TintLuminosityOpacity="0.65"
                        TintOpacity="0.48" />
                    <AcrylicBrush
                        x:Key="ShowOutputToolbarAcrylicBrush"
                        FallbackColor="{StaticResource ShowLayerAcrylicFallbackColor}"
                        TintColor="{StaticResource ShowLayerAcrylicTintColor}"
                        TintLuminosityOpacity="0.88"
                        TintOpacity="0.72" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="ShowChromeDividerBrush" Color="#1A000000" />
                    <SolidColorBrush x:Key="ShowOutputPanelResizeHoverBrush" Color="#66000000" />
                    <SolidColorBrush x:Key="ShowPanelActiveBorderBrush" Color="#40000000" />
                    <SolidColorBrush x:Key="ShowSlideDeckLiveOutlineBrush" Color="#FF22C55E" />
                    <windowsui:Color x:Key="ShowLayerAcrylicTintColor">#FFFFFFFF</windowsui:Color>
                    <windowsui:Color x:Key="ShowLayerAcrylicFallbackColor">#FFEDEDED</windowsui:Color>
                    <windowsui:Color x:Key="ShowCardAcrylicTintColor">#FFFFFFFF</windowsui:Color>
                    <windowsui:Color x:Key="ShowCardAcrylicFallbackColor">#FFF2F2F2</windowsui:Color>
                    <AcrylicBrush
                        x:Key="ShowBrowseDeckHeaderAcrylicBrush"
                        FallbackColor="{StaticResource ShowLayerAcrylicFallbackColor}"
                        TintColor="{StaticResource ShowLayerAcrylicTintColor}"
                        TintLuminosityOpacity="0.88"
                        TintOpacity="0.78" />
                    <AcrylicBrush
                        x:Key="ShowOutputPreviewCardAcrylicBrush"
                        FallbackColor="{StaticResource ShowCardAcrylicFallbackColor}"
                        TintColor="{StaticResource ShowCardAcrylicTintColor}"
                        TintLuminosityOpacity="0.9"
                        TintOpacity="0.82" />
                    <AcrylicBrush
                        x:Key="ShowMediaCardBackgroundAcrylicBrush"
                        FallbackColor="{StaticResource ShowCardAcrylicFallbackColor}"
                        TintColor="{StaticResource ShowCardAcrylicTintColor}"
                        TintLuminosityOpacity="0.92"
                        TintOpacity="0.88" />
                    <AcrylicBrush
                        x:Key="ShowMediaCardBorderAcrylicBrush"
                        FallbackColor="#33000000"
                        TintColor="{StaticResource ShowCardAcrylicTintColor}"
                        TintLuminosityOpacity="0.65"
                        TintOpacity="0.48" />
                    <AcrylicBrush
                        x:Key="ShowOutputToolbarAcrylicBrush"
                        FallbackColor="{StaticResource ShowLayerAcrylicFallbackColor}"
                        TintColor="{StaticResource ShowLayerAcrylicTintColor}"
                        TintLuminosityOpacity="0.88"
                        TintOpacity="0.72" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <!-- ~6% white scrim: blends with dark sidebar/output; avoids bright milky line (#33 was too strong). -->
                    <SolidColorBrush x:Key="ShowChromeDividerBrush" Color="#0FFFFFFF" />
                    <!-- Output panel: left edge when hovering resize strip (splitter is invisible; cursor = east-west). -->
                    <SolidColorBrush x:Key="ShowOutputPanelResizeHoverBrush" Color="#66FFFFFF" />
                    <SolidColorBrush x:Key="ShowPanelActiveBorderBrush" Color="#40FFFFFF" />
                    <SolidColorBrush x:Key="ShowSlideDeckLiveOutlineBrush" Color="#FF22C55E" />
                    <windowsui:Color x:Key="ShowLayerAcrylicTintColor">#FF323232</windowsui:Color>
                    <windowsui:Color x:Key="ShowLayerAcrylicFallbackColor">#FF1E1E1E</windowsui:Color>
                    <windowsui:Color x:Key="ShowCardAcrylicTintColor">#FF2D2D2D</windowsui:Color>
                    <windowsui:Color x:Key="ShowCardAcrylicFallbackColor">#FF1E1E1E</windowsui:Color>
                    <AcrylicBrush
                        x:Key="ShowBrowseDeckHeaderAcrylicBrush"
                        FallbackColor="{StaticResource ShowLayerAcrylicFallbackColor}"
                        TintColor="{StaticResource ShowLayerAcrylicTintColor}"
                        TintLuminosityOpacity="0.88"
                        TintOpacity="0.78" />
                    <AcrylicBrush
                        x:Key="ShowOutputPreviewCardAcrylicBrush"
                        FallbackColor="{StaticResource ShowCardAcrylicFallbackColor}"
                        TintColor="{StaticResource ShowCardAcrylicTintColor}"
                        TintLuminosityOpacity="0.9"
                        TintOpacity="0.82" />
                    <AcrylicBrush
                        x:Key="ShowMediaCardBackgroundAcrylicBrush"
                        FallbackColor="{StaticResource ShowCardAcrylicFallbackColor}"
                        TintColor="{StaticResource ShowCardAcrylicTintColor}"
                        TintLuminosityOpacity="0.92"
                        TintOpacity="0.88" />
                    <AcrylicBrush
                        x:Key="ShowMediaCardBorderAcrylicBrush"
                        FallbackColor="#33FFFFFF"
                        TintColor="{StaticResource ShowCardAcrylicTintColor}"
                        TintLuminosityOpacity="0.55"
                        TintOpacity="0.42" />
                    <AcrylicBrush
                        x:Key="ShowOutputToolbarAcrylicBrush"
                        FallbackColor="{StaticResource ShowLayerAcrylicFallbackColor}"
                        TintColor="{StaticResource ShowLayerAcrylicTintColor}"
                        TintLuminosityOpacity="0.88"
                        TintOpacity="0.72" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
            <converters:BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <Style x:Key="ShowOutputClearAppBarButtonStyle" TargetType="AppBarButton">
                <Setter Property="Background" Value="{ThemeResource AppBarButtonBackground}" />
                <Setter Property="Foreground" Value="{ThemeResource AppBarButtonForeground}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="VerticalAlignment" Value="Stretch" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="VerticalContentAlignment" Value="Stretch" />
                <Setter Property="Width" Value="Auto" />
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="MinHeight" Value="0" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="CornerRadius" Value="0" />
                <Setter Property="UseSystemFocusVisuals" Value="True" />
                <Setter Property="AllowFocusOnInteraction" Value="False" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="AppBarButton">
                            <Border
                                x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{TemplateBinding CornerRadius}">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="Root.Background" Value="{ThemeResource AppBarButtonBackgroundPointerOver}" />
                                                <Setter Target="Content.Foreground" Value="{ThemeResource AppBarButtonForegroundPointerOver}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <VisualState.Setters>
                                                <Setter Target="Root.Background" Value="{ThemeResource AppBarButtonBackgroundPressed}" />
                                                <Setter Target="Content.Foreground" Value="{ThemeResource AppBarButtonForegroundPressed}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Disabled">
                                            <VisualState.Setters>
                                                <Setter Target="Root.Background" Value="{ThemeResource AppBarButtonBackgroundDisabled}" />
                                                <Setter Target="Content.Foreground" Value="{ThemeResource AppBarButtonForegroundDisabled}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <Viewbox
                                    Width="18"
                                    Height="18"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                                    <ContentPresenter
                                        x:Name="Content"
                                        Content="{TemplateBinding Icon}"
                                        Foreground="{TemplateBinding Foreground}" />
                                </Viewbox>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style
                x:Key="ShowOutputClearPrimaryAppBarButtonStyle"
                BasedOn="{StaticResource ShowOutputClearAppBarButtonStyle}"
                TargetType="AppBarButton">
                <Setter Property="Background" Value="{ThemeResource AccentFillColorDefaultBrush}" />
                <Setter Property="Foreground" Value="{ThemeResource TextOnAccentFillColorPrimaryBrush}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="AppBarButton">
                            <Border
                                x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{TemplateBinding CornerRadius}">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="Root.Background" Value="{ThemeResource AccentFillColorSecondaryBrush}" />
                                                <Setter Target="Content.Foreground" Value="{ThemeResource TextOnAccentFillColorPrimaryBrush}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <VisualState.Setters>
                                                <Setter Target="Root.Background" Value="{ThemeResource AccentFillColorTertiaryBrush}" />
                                                <Setter Target="Content.Foreground" Value="{ThemeResource TextOnAccentFillColorSecondaryBrush}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Disabled">
                                            <VisualState.Setters>
                                                <Setter Target="Root.Background" Value="{ThemeResource AccentFillColorDisabledBrush}" />
                                                <Setter Target="Content.Foreground" Value="{ThemeResource TextOnAccentFillColorDisabledBrush}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <Viewbox
                                    Width="18"
                                    Height="18"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                                    <ContentPresenter
                                        x:Name="Content"
                                        Content="{TemplateBinding Icon}"
                                        Foreground="{TemplateBinding Foreground}" />
                                </Viewbox>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style
                x:Key="ShowOutputClearTintedAppBarButtonStyle"
                BasedOn="{StaticResource ShowOutputClearAppBarButtonStyle}"
                TargetType="AppBarButton">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="AppBarButton">
                            <Border
                                x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{TemplateBinding CornerRadius}">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="Content.Foreground" Value="{ThemeResource AppBarButtonForegroundPointerOver}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <VisualState.Setters>
                                                <Setter Target="Content.Foreground" Value="{ThemeResource AppBarButtonForegroundPressed}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Disabled">
                                            <VisualState.Setters>
                                                <Setter Target="Content.Foreground" Value="{ThemeResource AppBarButtonForegroundDisabled}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <Viewbox
                                    Width="18"
                                    Height="18"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                                    <ContentPresenter
                                        x:Name="Content"
                                        Content="{TemplateBinding Icon}"
                                        Foreground="{TemplateBinding Foreground}" />
                                </Viewbox>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        <converters:MillisecondsToSecondsLabelConverter x:Key="MsToSecondsLabelConverter" />
        <converters:BoolToThicknessConverter x:Key="BoolToThicknessConverter" />
        <converters:BoolToPlayPauseGlyphConverter x:Key="BoolToPlayPauseGlyphConverter" />
        <DataTemplate x:Key="SlideGroupMenuItemTemplate">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Border
                    Width="12"
                    Height="12"
                    VerticalAlignment="Center"
                    Background="{Binding Brush}"
                    CornerRadius="3" />
                <TextBlock
                    VerticalAlignment="Center"
                    Text="{Binding Label}" />
            </StackPanel>
        </DataTemplate>
        <Style x:Key="SlideGroupMenuFlyoutItemStyle" TargetType="MenuFlyoutItem">
            <Setter Property="MinWidth" Value="180" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuFlyoutItem">
                        <Grid
                            x:Name="Root"
                            MinHeight="{TemplateBinding MinHeight}"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SubtleFillColorTertiaryBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentControl
                                Content="{TemplateBinding Tag}"
                                ContentTemplate="{StaticResource SlideGroupMenuItemTemplate}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <DataTemplate x:Key="SlideContextNoThemeItemTemplate">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Border
                    Width="72"
                    Height="40"
                    Background="Black"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="5">
                    <Grid>
                        <Grid
                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                            ColumnDefinitions="*,*,*,*,*,*,*,*"
                            RowDefinitions="*,*,*,*">
                            <Rectangle Grid.Row="0" Grid.Column="0" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                            <Rectangle Grid.Row="0" Grid.Column="2" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                            <Rectangle Grid.Row="0" Grid.Column="4" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                            <Rectangle Grid.Row="0" Grid.Column="6" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                            <Rectangle Grid.Row="1" Grid.Column="1" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                            <Rectangle Grid.Row="1" Grid.Column="3" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                            <Rectangle Grid.Row="1" Grid.Column="5" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                            <Rectangle Grid.Row="1" Grid.Column="7" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                            <Rectangle Grid.Row="2" Grid.Column="0" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                            <Rectangle Grid.Row="2" Grid.Column="2" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                            <Rectangle Grid.Row="2" Grid.Column="4" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                            <Rectangle Grid.Row="2" Grid.Column="6" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                            <Rectangle Grid.Row="3" Grid.Column="1" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                            <Rectangle Grid.Row="3" Grid.Column="3" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                            <Rectangle Grid.Row="3" Grid.Column="5" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                            <Rectangle Grid.Row="3" Grid.Column="7" Fill="{ThemeResource SubtleFillColorSecondaryBrush}" />
                        </Grid>
                        <Border
                            Width="24"
                            Height="24"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                            <FontIcon
                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Glyph="&#xE711;" />
                        </Border>

                    </Grid>
                </Border>

                <TextBlock
                    VerticalAlignment="Center"
                    FontWeight="SemiBold"
                    Text="{Binding}" />
            </StackPanel>
        </DataTemplate>
        <Style x:Key="SlideContextNoThemeMenuFlyoutItemStyle" TargetType="MenuFlyoutItem">
            <Setter Property="MinWidth" Value="320" />
            <Setter Property="MinHeight" Value="56" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuFlyoutItem">
                        <Grid
                            x:Name="Root"
                            MinHeight="{TemplateBinding MinHeight}"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="Disabled">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="0.72" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentControl
                                Content="{TemplateBinding Tag}"
                                ContentTemplate="{StaticResource SlideContextNoThemeItemTemplate}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <CollectionViewSource
            x:Key="SlideDeckGroupedSource"
            IsSourceGrouped="True"
            ItemsPath="SlideRows"
            Source="{x:Bind ViewModel.SlideDeckGroupedSections, Mode=OneWay}" />
        <DataTemplate x:Key="ShowSlideDeckGroupHeaderTemplate">
            <TextBlock
                Margin="0,18,0,10"
                FontSize="16"
                FontWeight="SemiBold"
                Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                Text="{Binding Title}" />
        </DataTemplate>
        <Style
            x:Key="ShowGroupedDeckGridItemContainerStyle"
            BasedOn="{StaticResource DefaultGridViewItemStyle}"
            TargetType="GridViewItem">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
        <Style
            x:Key="ShowGroupedDeckListItemContainerStyle"
            BasedOn="{StaticResource DefaultListViewItemStyle}"
            TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <!-- Swatch: default Button template layers theme chrome over Background; this template paints Background on the root Border. -->
        <Style x:Key="ShowDeckColorSwatchButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="UseSystemFocusVisuals" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <!-- No ContentPresenter: default presenter can paint over TemplateBinding Background. -->
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Deck view mode: segments; hover fill uses TemplateBinding CornerRadius (set per segment to match outer Border radius 4). -->
        <Style x:Key="ShowDeckViewModeSegmentButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="UseSystemFocusVisuals" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="RootBorder"
                            Background="Transparent"
                            CornerRadius="{TemplateBinding CornerRadius}">
                            <Grid>
                                <Border
                                    x:Name="HoverBackground"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Background="Transparent"
                                    CornerRadius="{TemplateBinding CornerRadius}" />
                                <ContentPresenter
                                    x:Name="ContentPresenter"
                                    Padding="{TemplateBinding Padding}"
                                    HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                    Content="{TemplateBinding Content}"
                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                    ContentTransitions="{TemplateBinding ContentTransitions}" />
                            </Grid>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="HoverBackground.Background" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="HoverBackground.Background" Value="{ThemeResource SubtleFillColorTertiaryBrush}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <VisualState.Setters>
                                            <Setter Target="RootBorder.Opacity" Value="0.5" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ShowSlideDeckCardButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="UseSystemFocusVisuals" Value="False" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter
                            Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <DataTemplate x:Key="ShowSlideDeckCardTemplate" x:DataType="vm:ShowSlideDeckItem">
            <Button
                AllowDrop="True"
                AutomationProperties.Name="{x:Bind FooterLabel, Mode=OneWay}"
                Click="SlideDeckItem_Click"
                DragOver="SlideDeckItem_DragOver"
                Drop="SlideDeckItem_Drop"
                Opacity="{x:Bind CardOpacity, Mode=OneWay}"
                RightTapped="SlideDeckItem_RightTapped"
                Style="{StaticResource ShowSlideDeckCardButtonStyle}"
                Tag="{x:Bind}"
                x:Name="SlideDeckCardHost">
                <Button.ContextFlyout>
                    <MenuFlyout Opening="SlideDeckItemMenu_Opening" />
                </Button.ContextFlyout>
                <!-- Uniform: logical 228×H design scales as one unit to fill each grid cell (rows use full width; 8px gaps preserved). -->
                <Viewbox HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Stretch="Uniform">
                    <Grid
                        Width="{x:Bind ThumbnailCardOuterWidth, Mode=OneWay}"
                        Height="{x:Bind ThumbnailCardOuterHeight, Mode=OneWay}">
                        <Border
                            BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                            BorderThickness="6"
                            CornerRadius="11"
                            Canvas.ZIndex="1"
                            Visibility="{x:Bind ShowSelectedOutline, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
                        <Border
                            BorderBrush="{ThemeResource ShowSlideDeckLiveOutlineBrush}"
                            BorderThickness="2"
                            CornerRadius="6"
                            Margin="6"
                            Canvas.ZIndex="2"
                            Visibility="{x:Bind ShowLiveSlideOutputOutline, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
                        <Border
                            Margin="6"
                            Background="{x:Bind ThumbnailContainerBrush, Mode=OneWay}"
                            BorderThickness="0"
                            CornerRadius="6">
                            <Grid
                                Width="{x:Bind ThumbnailCardInnerWidth, Mode=OneWay}"
                                Height="{x:Bind ThumbnailCardInnerHeight, Mode=OneWay}"
                                RowDefinitions="Auto,Auto">
                                <Border
                                    Grid.Row="0"
                                    Width="{x:Bind ThumbnailPreviewWidth, Mode=OneWay}"
                                    Height="{x:Bind ThumbnailPreviewHeight, Mode=OneWay}"
                                    Margin="4,4,4,0"
                                    Background="Transparent"
                                    CornerRadius="5"
                                    VerticalAlignment="Top">
                                    <controls:SlideStageView
                                        Width="{x:Bind ThumbnailPreviewWidth, Mode=OneWay}"
                                        Height="{x:Bind ThumbnailPreviewHeight, Mode=OneWay}"
                                        HorizontalAlignment="Left"
                                        MediaLayers="{x:Bind ThumbnailMediaLayers, Mode=OneWay}"
                                        VerticalAlignment="Top"
                                        Project="{x:Bind ThumbnailProject, Mode=OneWay}"
                                        RenderMode="Thumbnail"
                                        Slide="{x:Bind ThumbnailPreviewSlide, Mode=OneWay}"
                                        ThumbnailBackgroundColor="{x:Bind ThumbnailBgColor, Mode=OneWay}" />
                                </Border>
                                <Grid
                                    Grid.Row="1"
                                    Height="{x:Bind ThumbnailFooterHeight, Mode=OneWay}"
                                    Padding="12,5,12,5"
                                    VerticalAlignment="Top">
                                    <Grid ColumnDefinitions="Auto,*">
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="11"
                                            FontWeight="SemiBold"
                                            Foreground="{x:Bind FooterForegroundBrush, Mode=OneWay}"
                                            Text="{x:Bind Ordinal}"
                                            TextLineBounds="Tight" />
                                        <TextBlock
                                            Grid.Column="1"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            FontSize="11"
                                            FontWeight="SemiBold"
                                            Foreground="{x:Bind FooterForegroundBrush, Mode=OneWay}"
                                            Text="{x:Bind FooterLabel}"
                                            TextLineBounds="Tight"
                                            TextTrimming="CharacterEllipsis"
                                            Visibility="{x:Bind ShowFooterSectionLabel, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>
                        <Border
                            Margin="10"
                            Padding="6,2"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Background="#B3000000"
                            CornerRadius="4"
                            Visibility="{x:Bind IsDisabled, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                            <TextBlock
                                FontSize="10"
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="Disabled" />
                        </Border>
                        <Border
                            Margin="10"
                            Padding="6,2"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Background="{ThemeResource AccentFillColorDefaultBrush}"
                            CornerRadius="4"
                            ToolTipService.ToolTip="{x:Bind SlideTransitionOverrideToolTip, Mode=OneWay}"
                            Visibility="{x:Bind HasSlideTransitionOverride, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon
                                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                    FontSize="10"
                                    Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                    Glyph="&#xE15A;" />
                                <TextBlock
                                    FontSize="10"
                                    FontWeight="SemiBold"
                                    Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                    Text="{x:Bind SlideTransitionOverrideBadgeText, Mode=OneWay}"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Viewbox>
            </Button>
        </DataTemplate>
        <!-- Text-only card: shows slide number + label + raw text; no thumbnail; font size is fixed. -->
        <DataTemplate x:Key="ShowSlideDeckTextCardTemplate" x:DataType="vm:ShowSlideDeckItem">
            <Button
                AllowDrop="True"
                AutomationProperties.Name="{x:Bind FooterLabel, Mode=OneWay}"
                Click="SlideDeckItem_Click"
                DragOver="SlideDeckItem_DragOver"
                Drop="SlideDeckItem_Drop"
                Opacity="{x:Bind CardOpacity, Mode=OneWay}"
                RightTapped="SlideDeckItem_RightTapped"
                Style="{StaticResource ShowSlideDeckCardButtonStyle}"
                Tag="{x:Bind}">
                <Button.ContextFlyout>
                    <MenuFlyout Opening="SlideDeckItemMenu_Opening" />
                </Button.ContextFlyout>
                <Grid>
                    <Border
                        BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                        BorderThickness="6"
                        CornerRadius="11"
                        Canvas.ZIndex="1"
                        Visibility="{x:Bind ShowSelectedOutline, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
                    <Border
                        BorderBrush="{ThemeResource ShowSlideDeckLiveOutlineBrush}"
                        BorderThickness="2"
                        CornerRadius="6"
                        Margin="6"
                        Canvas.ZIndex="2"
                        Visibility="{x:Bind ShowLiveSlideOutputOutline, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
                    <Border
                        Margin="6"
                        Background="{x:Bind ThumbnailContainerBrush, Mode=OneWay}"
                        BorderThickness="0"
                        CornerRadius="6"
                        Padding="10,8">
                        <StackPanel Spacing="4">
                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock
                                    Grid.Column="0"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Foreground="{x:Bind FooterForegroundBrush, Mode=OneWay}"
                                    Text="{x:Bind Ordinal}"
                                    TextLineBounds="Tight" />
                                <TextBlock
                                    Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Foreground="{x:Bind FooterForegroundBrush, Mode=OneWay}"
                                    Text="{x:Bind FooterLabel}"
                                    TextLineBounds="Tight"
                                    TextTrimming="CharacterEllipsis"
                                    Visibility="{x:Bind ShowFooterSectionLabel, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
                            </Grid>
                            <TextBlock
                                FontSize="13"
                                Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                LineHeight="18"
                                MaxLines="5"
                                Text="{x:Bind RawText, Mode=OneWay}"
                                TextTrimming="CharacterEllipsis"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Border>
                    <Border
                        Margin="10"
                        Padding="6,2"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Background="#B3000000"
                        CornerRadius="4"
                        Visibility="{x:Bind IsDisabled, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                        <TextBlock
                            FontSize="10"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="Disabled" />
                    </Border>
                    <Border
                        Margin="10"
                        Padding="6,2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                        CornerRadius="4"
                        ToolTipService.ToolTip="{x:Bind SlideTransitionOverrideToolTip, Mode=OneWay}"
                        Visibility="{x:Bind HasSlideTransitionOverride, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon
                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                FontSize="10"
                                Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                Glyph="&#xE15A;" />
                            <TextBlock
                                FontSize="10"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                Text="{x:Bind SlideTransitionOverrideBadgeText, Mode=OneWay}"
                                TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Button>
        </DataTemplate>

        <!-- List-view row: small thumbnail on the left, raw text on the right; row height driven by DeckListItemHeight. -->
        <DataTemplate x:Key="ShowSlideDeckListItemTemplate" x:DataType="vm:ShowSlideDeckItem">
            <Button
                AllowDrop="True"
                AutomationProperties.Name="{x:Bind FooterLabel, Mode=OneWay}"
                Click="SlideDeckItem_Click"
                DragOver="SlideDeckItem_DragOver"
                Drop="SlideDeckItem_Drop"
                Opacity="{x:Bind CardOpacity, Mode=OneWay}"
                RightTapped="SlideDeckItem_RightTapped"
                Style="{StaticResource ShowSlideDeckCardButtonStyle}"
                Tag="{x:Bind}">
                <Button.ContextFlyout>
                    <MenuFlyout Opening="SlideDeckItemMenu_Opening" />
                </Button.ContextFlyout>
                <Grid Margin="0,1">
                    <Border
                        BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                        BorderThickness="6"
                        CornerRadius="9"
                        Canvas.ZIndex="1"
                        Visibility="{x:Bind ShowSelectedOutline, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
                    <Border
                        BorderBrush="{ThemeResource ShowSlideDeckLiveOutlineBrush}"
                        BorderThickness="2"
                        CornerRadius="5"
                        Margin="6"
                        Canvas.ZIndex="2"
                        Visibility="{x:Bind ShowLiveSlideOutputOutline, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
                    <Border
                        Margin="6"
                        Background="{x:Bind ThumbnailContainerBrush, Mode=OneWay}"
                        BorderThickness="0"
                        CornerRadius="5">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" Padding="8,6">
                            <!-- Thumbnail -->
                            <Border Grid.Column="0" CornerRadius="3">
                                <controls:SlideStageView
                                    Width="{x:Bind DeckListThumbWidth, Mode=OneWay}"
                                    Height="{x:Bind DeckListItemHeight, Mode=OneWay}"
                                    RenderMode="Thumbnail"
                                    MediaLayers="{x:Bind ThumbnailMediaLayers, Mode=OneWay}"
                                    Project="{x:Bind ThumbnailProject, Mode=OneWay}"
                                    Slide="{x:Bind ThumbnailPreviewSlide, Mode=OneWay}"
                                    ThumbnailBackgroundColor="{x:Bind ThumbnailBgColor, Mode=OneWay}" />
                            </Border>
                            <!-- Text content -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3">
                                <Grid ColumnDefinitions="Auto,*">
                                    <TextBlock
                                        Grid.Column="0"
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Foreground="{x:Bind FooterForegroundBrush, Mode=OneWay}"
                                        Text="{x:Bind Ordinal}"
                                        TextLineBounds="Tight" />
                                    <TextBlock
                                        Grid.Column="1"
                                        HorizontalAlignment="Right"
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Foreground="{x:Bind FooterForegroundBrush, Mode=OneWay}"
                                        Text="{x:Bind FooterLabel}"
                                        TextLineBounds="Tight"
                                        TextTrimming="CharacterEllipsis"
                                        Visibility="{x:Bind ShowFooterSectionLabel, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
                                </Grid>
                                <TextBlock
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                    LineHeight="17"
                                    MaxLines="3"
                                    Text="{x:Bind RawText, Mode=OneWay}"
                                    TextTrimming="CharacterEllipsis"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border
                        Margin="10,6"
                        Padding="6,2"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Background="#B3000000"
                        CornerRadius="4"
                        Visibility="{x:Bind IsDisabled, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                        <TextBlock
                            FontSize="10"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="Disabled" />
                    </Border>
                    <Border
                        Margin="10,6"
                        Padding="6,2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                        CornerRadius="4"
                        ToolTipService.ToolTip="{x:Bind SlideTransitionOverrideToolTip, Mode=OneWay}"
                        Visibility="{x:Bind HasSlideTransitionOverride, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon
                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                FontSize="10"
                                Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                Glyph="&#xE15A;" />
                            <TextBlock
                                FontSize="10"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                Text="{x:Bind SlideTransitionOverrideBadgeText, Mode=OneWay}"
                                TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Button>
        </DataTemplate>

        <Style x:Key="ShowSidebarSectionTitleTextStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionTextBlockStyle}">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
        </Style>
        <!-- Section toolbar: compact add/import next to sidebar titles. -->
        <Style
            x:Key="ShowSidebarSectionToolbarButtonStyle"
            BasedOn="{StaticResource DefaultButtonStyle}"
            TargetType="Button">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>

        <MenuFlyout x:Key="MediaItemContextMenuFlyout" Opening="MediaItemContextMenu_Opening">
            <MenuFlyoutItem IsEnabled="False" Text="Inspector..." />
            <MenuFlyoutItem Click="MediaItemEditTransition_Click" Text="Transitions..." />
            <MenuFlyoutSubItem Text="Behavior">
                <MenuFlyoutItem Click="MediaCueTarget_Click" Tag="mediaUnderlay" Text="Media Underlay" />
                <MenuFlyoutItem Click="MediaCueTarget_Click" Tag="mediaOverlay" Text="Media Overlay" />
                <MenuFlyoutItem Click="MediaCueTarget_Click" Tag="audio" Text="Audio" />
            </MenuFlyoutSubItem>
            <MenuFlyoutSubItem Text="Scaling">
                <MenuFlyoutItem Click="MediaCueFit_Click" Tag="cover" Text="Cover" />
                <MenuFlyoutItem Click="MediaCueFit_Click" Tag="contain" Text="Contain" />
                <MenuFlyoutItem Click="MediaCueFit_Click" Tag="fill" Text="Fill" />
                <MenuFlyoutItem Click="MediaCueFit_Click" Tag="none" Text="None" />
            </MenuFlyoutSubItem>
            <MenuFlyoutSubItem Text="Playback Behavior">
                <ToggleMenuFlyoutItem Click="MediaCueAutoplay_Click" Text="Autoplay" />
                <ToggleMenuFlyoutItem Click="MediaCueMuted_Click" Text="Muted" />
            </MenuFlyoutSubItem>
            <MenuFlyoutSubItem Text="Loop Behavior">
                <ToggleMenuFlyoutItem Click="MediaCueLoop_Click" Text="Loop" />
            </MenuFlyoutSubItem>
            <MenuFlyoutSubItem IsEnabled="False" Text="End Behavior" />
            <MenuFlyoutSubItem IsEnabled="False" Text="Next Cue" />
            <MenuFlyoutSeparator />
            <MenuFlyoutItem IsEnabled="False" Text="Cut" />
            <MenuFlyoutItem IsEnabled="False" Text="Copy" />
            <MenuFlyoutItem IsEnabled="False" Text="Paste" />
            <MenuFlyoutItem Click="MediaItemDuplicate_Click" Text="Duplicate" />
            <MenuFlyoutItem Click="MediaItemRename_Click" Text="Rename" />
            <MenuFlyoutItem Click="MediaItemDelete_Click" Text="Delete" />
            <MenuFlyoutSeparator />
            <MenuFlyoutItem Click="MediaItemOpenFileLocation_Click" Text="Open File Location" />
            <MenuFlyoutSubItem IsEnabled="False" Text="Clean Up By" />
        </MenuFlyout>
        </ResourceDictionary>
    </Page.Resources>

    <!-- NavigationView pane flush to the window edge; no outer inset Border. MainWindow tab bar is unchanged. -->
    <Grid
        x:Name="LayoutRoot"
        Background="Transparent"
        PointerPressed="LayoutRoot_PointerPressed">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="320" />
            <ColumnDefinition
                x:Name="OutputPanelColumn"
                Width="460"
                MinWidth="360"
                MaxWidth="560" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition x:Name="MediaPanelContentRow" Height="0" />
        </Grid.RowDefinitions>
        <Button
            x:Name="KeyboardFocusTarget"
            Grid.ColumnSpan="2"
            Width="0"
            Height="0"
            Padding="0"
            Margin="0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Background="Transparent"
            BorderThickness="0"
            IsTabStop="True"
            Opacity="0"
            UseSystemFocusVisuals="False" />
        <NavigationView
            x:Name="ShowNavigationView"
            Grid.Column="0"
            Grid.Row="0"
            Padding="0"
            Background="Transparent"
            CompactPaneLength="280"
            IsBackButtonVisible="Collapsed"
            IsPaneOpen="True"
            IsPaneToggleButtonVisible="False"
            IsSettingsVisible="False"
            IsTitleBarAutoPaddingEnabled="False"
            OpenPaneLength="280"
            PaneDisplayMode="Left"
            ItemInvoked="ShowNavigationView_ItemInvoked"
            SelectionChanged="ShowNavigationView_SelectionChanged">

            <NavigationView.AutoSuggestBox>
                <AutoSuggestBox
                    x:Name="SourcesSearchBox"
                    AutomationProperties.Name="Search presentations"
                    HorizontalAlignment="Stretch"
                    PlaceholderText="Search presentations"
                    QueryIcon="Find"
                    QuerySubmitted="SourcesSearchBox_QuerySubmitted"
                    SuggestionChosen="SourcesSearchBox_SuggestionChosen"
                    TextChanged="SourcesSearchBox_TextChanged"
                    Visibility="{x:Bind ViewModel.HasPresentationSources, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
            </NavigationView.AutoSuggestBox>

            <NavigationView.PaneCustomContent>
                <Grid
                    Margin="16,0,16,8"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">
                    <SplitButton
                        x:Name="ShowContentSplitButton"
                        Content="Create library"
                        Click="ShowContentSplitButton_Click"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Padding="{ThemeResource ButtonPadding}"
                        VerticalContentAlignment="Center"
                        AutomationProperties.AutomationId="ShowContentSplitButton"
                        AutomationProperties.Name="Create library"
                        ToolTipService.ToolTip="Create or import content">
                        <SplitButton.Resources>
                            <StaticResource x:Key="SplitButtonBackground" ResourceKey="ButtonBackground" />
                            <StaticResource x:Key="SplitButtonBackgroundPointerOver" ResourceKey="ButtonBackgroundPointerOver" />
                            <StaticResource x:Key="SplitButtonBackgroundPressed" ResourceKey="ButtonBackgroundPressed" />
                            <StaticResource x:Key="SplitButtonBackgroundDisabled" ResourceKey="ButtonBackgroundDisabled" />
                            <StaticResource x:Key="SplitButtonBorderBrush" ResourceKey="ButtonBorderBrush" />
                            <StaticResource x:Key="SplitButtonBorderBrushPointerOver" ResourceKey="ButtonBorderBrushPointerOver" />
                            <StaticResource x:Key="SplitButtonBorderBrushPressed" ResourceKey="ButtonBorderBrushPressed" />
                            <StaticResource x:Key="SplitButtonBorderBrushDisabled" ResourceKey="ButtonBorderBrushDisabled" />
                            <StaticResource x:Key="SplitButtonForeground" ResourceKey="ButtonForeground" />
                            <StaticResource x:Key="SplitButtonForegroundPointerOver" ResourceKey="ButtonForegroundPointerOver" />
                            <StaticResource x:Key="SplitButtonForegroundPressed" ResourceKey="ButtonForegroundPressed" />
                            <StaticResource x:Key="SplitButtonForegroundDisabled" ResourceKey="ButtonForegroundDisabled" />
                        </SplitButton.Resources>
                        <SplitButton.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Click="LibraryNewLibrary_Click" Text="Create library" />
                                <MenuFlyoutItem Click="LibrariesSectionImportFolder_Click" Text="Import library folder..." />
                                <MenuFlyoutItem Click="LibrariesSectionImportPackage_Click" Text="Import library package..." />
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem Click="LibraryNewPlaylist_Click" Text="Create playlist" />
                                <MenuFlyoutItem Click="PlaylistsSectionImportPackage_Click" Text="Import playlist package..." />
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem Click="ShowCreatePresentation_Click" Text="Create presentation" />
                                <MenuFlyoutItem Click="ShowImportPresentation_Click" Text="Import presentation..." />
                            </MenuFlyout>
                        </SplitButton.Flyout>
                    </SplitButton>
                </Grid>
            </NavigationView.PaneCustomContent>

            <Grid>
                <!-- NavigationView content: presentation area only.
                     The media panel is stacked below the NavigationView on the root grid,
                     and the output panel sits outside on the right. -->
                <Grid RowDefinitions="*,Auto">

                    <!-- Row 0: slide-deck scroll area; scrollbar flush to the right edge (horizontal inset lives on each presentation section). -->
                    <Grid
                        Grid.Row="0"
                        MinHeight="0">
                        <StackPanel
                            MaxWidth="240"
                            Canvas.ZIndex="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="10"
                            Visibility="{x:Bind ViewModel.ShowPresentationSourcesEmpty, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                            <Border
                                Width="44"
                                Height="44"
                                HorizontalAlignment="Center"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                                <FontIcon
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                    FontSize="20"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Glyph="&#xE8F1;" />
                            </Border>
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                Text="No presentation sources yet"
                                TextAlignment="Center"
                                TextWrapping="WrapWholeWords" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Create a library or playlist to start organizing presentations for the show."
                                TextAlignment="Center"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>

                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Select a library or playlist to browse presentations."
                            Visibility="{x:Bind ViewModel.ShowPresentationHomePrompt, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />

                        <Grid
                            MinHeight="0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Visibility="{x:Bind ViewModel.ShowHome, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert, Mode=OneWay}">
                        <StackPanel
                            MaxWidth="240"
                            Canvas.ZIndex="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="10"
                            Visibility="{x:Bind ViewModel.ShowBrowseStackEmpty, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                            <Border
                                Width="44"
                                Height="44"
                                HorizontalAlignment="Center"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                                <FontIcon
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                    FontSize="20"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Glyph="&#xE8F1;" />
                            </Border>
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                Text="No presentations yet"
                                TextAlignment="Center"
                                TextWrapping="WrapWholeWords" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Add presentations to this library or playlist to start building the show."
                                TextAlignment="Center"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>

                        <!-- Browse stack: thumbnail mode -->
                        <ScrollViewer
                            x:Name="BrowseStackScrollViewer"
                            Padding="0"
                            HorizontalScrollMode="Disabled"
                            VerticalScrollBarVisibility="Auto"
                            Visibility="{x:Bind ViewModel.ShowBrowseStack, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                            <StackPanel Padding="0,12,0,12" Spacing="12">
                                <ItemsControl
                                    x:Name="BrowseStackItemsControl"
                                    ItemsSource="{x:Bind ViewModel.BrowseStackSections, Mode=OneWay}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Vertical" Spacing="12" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ShowPresentationDeckSection">
                                            <StackPanel Padding="12,0,12,0" Spacing="8">
                                                <Border
                                                    Padding="8,8"
                                                    Background="{ThemeResource ShowBrowseDeckHeaderAcrylicBrush}"
                                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="4">
                                                    <StackPanel Spacing="6">
                                                        <!-- Title row: title + duration + action buttons -->
