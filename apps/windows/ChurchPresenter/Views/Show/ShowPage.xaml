                                                    Width="32"
                                                    Height="28"
                                                    Padding="0"
                                                    HorizontalContentAlignment="Stretch"
                                                    VerticalContentAlignment="Stretch"
                                                    Style="{StaticResource ShowDeckColorSwatchButtonStyle}"
                                                    AutomationProperties.Name="Choose slide background color"
                                                    ToolTipService.ToolTip="Choose slide background color">
                                                    <Button.Background>
                                                        <SolidColorBrush Color="{x:Bind ViewModel.TransparentThumbnailColorWinUI, Mode=OneWay}" />
                                                    </Button.Background>
                                                    <Button.Flyout>
                                                        <Flyout
                                                            x:Name="ThumbnailBgColorFlyout"
                                                            Opening="ThumbnailBgColorFlyout_Opening"
                                                            Placement="TopEdgeAlignedRight">
                                                            <StackPanel MinWidth="240" Spacing="10">
                                                                <ColorPicker
                                                                    x:Name="ThumbnailBgColorPicker"
                                                                    ColorSpectrumShape="Box"
                                                                    IsAlphaEnabled="False"
                                                                    IsColorChannelTextInputVisible="False"
                                                                    IsColorPreviewVisible="False"
                                                                    IsMoreButtonVisible="False"
                                                                    IsHexInputVisible="False"
                                                                    ColorChanged="ThumbnailBgColorPicker_ColorChanged" />
                                                                <!-- Opacity -->
                                                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                                                    <TextBlock
                                                                        Grid.Column="0"
                                                                        VerticalAlignment="Center"
                                                                        FontSize="13"
                                                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                        Text="Opacity" />
                                                                    <Slider
                                                                        Grid.Column="1"
                                                                        x:Name="DeckOpacitySlider"
                                                                        VerticalAlignment="Center"
                                                                        Maximum="100"
                                                                        Minimum="0"
                                                                        StepFrequency="1"
                                                                        TickPlacement="None"
                                                                        Value="{x:Bind ViewModel.TransparentThumbnailOpacity, Mode=OneWay}"
                                                                        ValueChanged="DeckOpacitySlider_ValueChanged" />
                                                                    <TextBlock
                                                                        Grid.Column="2"
                                                                        Width="32"
                                                                        VerticalAlignment="Center"
                                                                        FontSize="13"
                                                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                        Text="{x:Bind ViewModel.TransparentThumbnailOpacity, Mode=OneWay}"
                                                                        TextAlignment="Right" />
                                                                </Grid>
                                                            </StackPanel>
                                                        </Flyout>
                                                    </Button.Flyout>
                                                </Button>
                                            </Grid>

                                        </StackPanel>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </NavigationView>

        <!-- Media panel: outer chrome transparent so playlist column matches main shell; LayerFill only on browse column (col 1). -->
        <Border
            x:Name="MediaPanelChromeBorder"
            Grid.Column="0"
            Grid.Row="1"
            Background="Transparent"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <Grid>
                <Grid
                    x:Name="MediaPanelContentGrid"
                    ColumnDefinitions="282,*"
                    Background="Transparent">

                    <!-- Col 0: playlist sidebar (transparent; MainWindow shell shows through). -->
                    <Grid
                        Grid.Column="0"
                        RowDefinitions="Auto,*"
                        Background="Transparent"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="0,0,1,0">
                        <!-- Header: section title + new playlist (match main Show sidebar section header) -->
                        <Border
                            Grid.Row="0"
                            Padding="10,8,10,6"
                            Background="Transparent">
                            <Grid ColumnDefinitions="*,Auto" Padding="2,0,2,2">
                                <TextBlock
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource ShowSidebarSectionTitleTextStyle}"
                                    Text="Media" />
                                <StackPanel
                                    Grid.Column="1"
                                    Orientation="Horizontal"
                                    Spacing="4">
                                    <Button
                                        AutomationProperties.Name="New media playlist"
                                        Click="AddMediaPlaylist_Click"
                                        Style="{StaticResource ShowSidebarSectionToolbarButtonStyle}"
                                        ToolTipService.ToolTip="New playlist">
                                        <FontIcon
                                            FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                            FontSize="14"
                                            Glyph="&#xE710;" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <!-- Playlist list -->
                        <ScrollViewer
                            Grid.Row="1"
                            Padding="0"
                            Background="Transparent"
                            VerticalScrollBarVisibility="Auto">
                            <StackPanel Padding="10,6,10,6" Spacing="2">
                                <!-- "All Media" entry -->
                                <Button
                                    x:Name="MediaPlaylistAllButton"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    Padding="8,6"
                                    AutomationProperties.Name="All media"
                                    Click="MediaPlaylistAll_Click"
                                    Style="{StaticResource SubtleButtonStyle}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon
                                            FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                            FontSize="12"
                                            Glyph="&#xE93C;" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            Text="All Media"
                                            TextTrimming="CharacterEllipsis"
                                            TextWrapping="NoWrap" />
                                    </StackPanel>
                                </Button>
                                <!-- Playlist entries -->
                                <ItemsControl
                                    x:Name="MediaPlaylistItemsControl"
                                    ItemsSource="{x:Bind ViewModel.MediaPlaylists, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:MediaPlaylistManifest">
                                            <Button
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Left"
                                                Padding="8,6"
                                                Click="MediaPlaylistItem_Click"
                                                Style="{StaticResource SubtleButtonStyle}"
                                                Tag="{x:Bind Id, Mode=OneTime}">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <FontIcon
                                                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                        FontSize="12"
                                                        Glyph="&#xE93C;" />
                                                    <TextBlock
                                                        VerticalAlignment="Center"
                                                        FontSize="12"
                                                        Text="{x:Bind Name, Mode=OneTime}"
                                                        TextTrimming="CharacterEllipsis"
                                                        TextWrapping="NoWrap" />
                                                </StackPanel>
                                                <Button.ContextFlyout>
                                                    <MenuFlyout>
                                                        <MenuFlyoutItem
                                                            Click="RenameMediaPlaylist_Click"
                                                            Tag="{x:Bind Id, Mode=OneTime}"
                                                            Text="Rename" />
                                                        <MenuFlyoutSeparator />
                                                        <MenuFlyoutItem
                                                            Click="DeleteMediaPlaylist_Click"
                                                            Tag="{x:Bind Id, Mode=OneTime}"
                                                            Text="Delete" />
                                                    </MenuFlyout>
                                                </Button.ContextFlyout>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- Col 1: files browse — LayerFillColorDefaultBrush (same material as OutputPanelChromeBorder), not the playlist column. -->
                    <Grid
                        Grid.Column="1"
                        RowDefinitions="Auto,*,Auto"
                        Background="{ThemeResource LayerFillColorDefaultBrush}">

                        <!-- Top toolbar: add media on the left, search on the right. -->
                        <Border
                            Grid.Row="0"
                            Padding="0"
                            Background="{ThemeResource ShowBrowseDeckHeaderAcrylicBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="0,0,0,1">
                            <Grid
                                Padding="8,5"
                                ColumnDefinitions="Auto,*"
                                ColumnSpacing="8">
                                <Button
                                    Grid.Column="0"
                                    MinHeight="30"
                                    Padding="8,0"
                                    AutomationProperties.Name="Add media files"
                                    Click="AddMediaFiles_Click"
                                    Style="{StaticResource DefaultButtonStyle}"
                                    ToolTipService.ToolTip="Add media files">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon
                                            FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                            FontSize="14"
                                            Glyph="&#xE710;" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            Text="Add media" />
                                    </StackPanel>
                                </Button>
                                <AutoSuggestBox
                                    Grid.Column="1"
                                    Width="260"
                                    MinWidth="180"
                                    HorizontalAlignment="Right"
                                    PlaceholderText="Search media..."
                                    Text="{x:Bind ViewModel.MediaPanelSearchText, Mode=TwoWay}"
                                    QueryIcon="Find" />
                            </Grid>
                        </Border>

                        <!-- Grid view: uniform thumbnail cards (fixed 16:9 preview + footer in each cell). -->
                        <ScrollViewer
                            x:Name="MediaPanelGridScrollViewer"
                            Grid.Row="1"
                            Padding="8"
                            VerticalScrollBarVisibility="Auto"
                            Visibility="{x:Bind ViewModel.MediaPanelIsGridMode, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                            <ItemsRepeater
                                x:Name="MediaPanelGridRepeater"
                                ItemsSource="{x:Bind ViewModel.MediaPanelItems, Mode=OneWay}">
                                <ItemsRepeater.Layout>
                                    <UniformGridLayout
                                        ItemsStretch="Fill"
                                        MaximumRowsOrColumns="20"
                                        MinColumnSpacing="8"
                                        MinItemHeight="{x:Bind ViewModel.MediaPanelGridMinItemHeight, Mode=OneWay}"
                                        MinItemWidth="{x:Bind ViewModel.MediaPanelGridMinItemWidth, Mode=OneWay}"
                                        MinRowSpacing="8" />
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="vm:MediaPanelItemViewModel">
                                        <Border
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Stretch"
                                            MinWidth="0"
                                            MinHeight="0"
                                            Padding="0"
                                            AutomationProperties.Name="{x:Bind Name, Mode=OneTime}"
                                            Background="Transparent"
                                            CanDrag="True"
                                            ContextRequested="MediaItem_ContextRequested"
                                            DragStarting="MediaItem_DragStarting"
                                            IsTabStop="False"
                                            PointerEntered="MediaGridItem_PointerEntered"
                                            Tag="{x:Bind Id, Mode=OneTime}"
                                            Tapped="MediaGridItem_Tapped"
                                            ToolTipService.ToolTip="{x:Bind Name, Mode=OneTime}">
                                            <Border
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Stretch"
                                                Background="{ThemeResource ShowMediaCardBackgroundAcrylicBrush}"
                                                BorderBrush="{ThemeResource ShowMediaCardBorderAcrylicBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8">
                                                <!-- * row fills remaining cell height so acrylic ends at the footer (no dead band under the info bar). -->
                                                <Grid RowDefinitions="*,Auto">
                                                    <Border
                                                        Grid.Row="0"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Stretch"
                                                        CornerRadius="8,8,0,0">
                                                        <Grid>
                                                            <!-- No-thumbnail fallback: slightly darker than the info bar so the frame reads clearly. -->
                                                            <Border
                                                                HorizontalAlignment="Stretch"
                                                                VerticalAlignment="Stretch"
                                                                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                                                Visibility="{x:Bind HasThumbnail, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert, Mode=OneWay}" />
                                                            <Border
                                                                HorizontalAlignment="Stretch"
                                                                VerticalAlignment="Stretch"
                                                                Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                                                                Visibility="{x:Bind HasThumbnail, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
                                                            <Image
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                Source="{x:Bind ThumbnailSource, Mode=OneWay}"
                                                                Stretch="Uniform"
                                                                Visibility="{x:Bind HasThumbnail, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
                                                            <Viewbox
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                MaxWidth="56"
                                                                MaxHeight="56"
                                                                Stretch="Uniform"
                                                                Visibility="{x:Bind HasThumbnail, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert, Mode=OneWay}">
                                                                <FontIcon
                                                                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                                    FontSize="128"
                                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                    Glyph="{x:Bind TypeGlyph, Mode=OneWay}" />
                                                            </Viewbox>
                                                        </Grid>
                                                    </Border>
                                                    <Grid
                                                        Grid.Row="1"
                                                        Padding="12,11"
                                                        MinHeight="48"
                                                        Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                                                        ColumnDefinitions="*,Auto"
                                                        ColumnSpacing="10">
                                                        <TextBlock
                                                            Grid.Column="0"
                                                            VerticalAlignment="Center"
                                                            FontSize="13"
                                                            FontWeight="SemiBold"
                                                            Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                            Text="{x:Bind Name, Mode=OneTime}"
                                                            TextTrimming="CharacterEllipsis"
                                                            TextWrapping="NoWrap" />
                                                        <StackPanel
                                                            Grid.Column="1"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Center"
                                                            Orientation="Horizontal"
                                                            Spacing="6">
                                                            <TextBlock
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Center"
                                                                FontSize="12"
                                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                Text="{x:Bind FooterRightMetaText, Mode=OneWay}"
                                                                TextAlignment="Right"
                                                                Visibility="{x:Bind HasFooterRightMetaText, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
                                                            <FontIcon
                                                                VerticalAlignment="Center"
                                                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                                FontSize="12"
                                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                Glyph="{x:Bind TypeGlyph, Mode=OneWay}"
                                                                ToolTipService.ToolTip="{x:Bind TypeDisplayName, Mode=OneWay}"
                                                                AutomationProperties.Name="{x:Bind TypeDisplayName, Mode=OneWay}" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </Border>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </ScrollViewer>

                        <!-- List view: table header + rows (index column has no header label; thumbnail, transition, name, path, duration, format). -->
                        <Grid
                            Grid.Row="1"
                            RowDefinitions="Auto,*"
                            Visibility="{x:Bind ViewModel.MediaPanelIsListMode, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                            <Border
                                Grid.Row="0"
                                Padding="4,6,12,6"
                                Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="0,0,0,1">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <!-- Index: reserved header cell, no label (aligns with row numbers). -->
                                        <ColumnDefinition Width="Auto" MinWidth="28" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" MinWidth="148" />
                                        <ColumnDefinition Width="1.4*" MinWidth="120" />
                                        <ColumnDefinition Width="2.2*" MinWidth="160" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="96" />
                                    </Grid.ColumnDefinitions>
                                    <Border
                                        Grid.Column="0"
                                        MinWidth="28"
                                        HorizontalAlignment="Stretch"
                                        Background="Transparent" />
                                    <TextBlock
                                        Grid.Column="1"
                                        MinWidth="{x:Bind ViewModel.MediaPanelListThumbWidth, Mode=OneWay}"
                                        VerticalAlignment="Center"
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="Thumbnail"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        Grid.Column="2"
                                        VerticalAlignment="Center"
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="Transition"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        Grid.Column="3"
                                        VerticalAlignment="Center"
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="Name"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        Grid.Column="4"
                                        VerticalAlignment="Center"
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="Path"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        Grid.Column="5"
                                        VerticalAlignment="Center"
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="Duration"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        Grid.Column="6"
                                        VerticalAlignment="Center"
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="Format"
                                        TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Border>
                            <ListView
                                x:Name="MediaPanelListView"
                                Grid.Row="1"
                                IsItemClickEnabled="True"
                                ItemClick="MediaPanelListView_ItemClick"
                                ItemsSource="{x:Bind ViewModel.MediaPanelItems, Mode=OneWay}"
                                KeyDown="MediaPanelListView_KeyDown"
                                SelectionMode="Single">
                                <ListView.ItemContainerStyle>
                                    <Style BasedOn="{StaticResource DefaultListViewItemStyle}" TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="MinHeight" Value="{Binding ElementName=RootPage, Path=ViewModel.MediaPanelListRowMinHeight}" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:MediaPanelItemViewModel">
                                        <Grid
                                            Padding="4,6,12,6"
                                            HorizontalAlignment="Stretch"
                                            Background="Transparent"
                                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                            BorderThickness="0,0,0,1"
                                            CanDrag="True"
                                            ColumnSpacing="8"
                                            ContextRequested="MediaItem_ContextRequested"
                                            DragStarting="MediaItem_DragStarting"
                                            PointerEntered="MediaListItem_PointerEntered"
                                            Tag="{x:Bind Id, Mode=OneTime}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" MinWidth="28" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" MinWidth="148" />
                                                <ColumnDefinition Width="1.4*" MinWidth="120" />
                                                <ColumnDefinition Width="2.2*" MinWidth="160" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="96" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                Grid.Column="0"
                                                Margin="0,0,20,0"
                                                VerticalAlignment="Center"
                                                FontSize="14"
                                                FontWeight="SemiBold"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="{x:Bind DisplayIndex, Mode=OneWay}"
                                                TextAlignment="Right" />
                                            <Border
                                                Grid.Column="1"
                                                Width="{Binding ElementName=RootPage, Path=ViewModel.MediaPanelListThumbWidth}"
                                                Height="{Binding ElementName=RootPage, Path=ViewModel.MediaPanelListThumbHeight}"
                                                VerticalAlignment="Center"
                                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                CornerRadius="4">
                                                <Grid>
                                                    <Border
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Stretch"
                                                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                                        Visibility="{x:Bind HasThumbnail, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert, Mode=OneWay}" />
                                                    <Image
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Source="{x:Bind ThumbnailSource, Mode=OneWay}"
                                                        Stretch="Uniform"
                                                        Visibility="{x:Bind HasThumbnail, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
                                                    <Viewbox
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        MaxWidth="22"
                                                        MaxHeight="22"
                                                        Stretch="Uniform"
                                                        Visibility="{x:Bind HasThumbnail, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert, Mode=OneWay}">
                                                        <FontIcon
                                                            FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                            FontSize="128"
                                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                            Glyph="{x:Bind TypeGlyph, Mode=OneWay}" />
                                                    </Viewbox>
                                                </Grid>
                                            </Border>
                                            <StackPanel
                                                Grid.Column="2"
                                                VerticalAlignment="Center"
                                                Orientation="Horizontal"
                                                Spacing="8">
                                                <FontIcon
                                                    VerticalAlignment="Center"
                                                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                    FontSize="14"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Glyph="&#xE102;"
                                                    ToolTipService.ToolTip="Per-file transition (see context menu)"
                                                    Visibility="{x:Bind IsMediaTransitionExplicit, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontSize="12"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Text="{x:Bind MediaTableTransitionDisplay, Mode=OneWay}"
                                                    TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <Grid Grid.Column="3" VerticalAlignment="Center">
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontSize="13"
                                                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                    IsTapEnabled="True"
                                                    Text="{x:Bind Name, Mode=OneWay}"
                                                    TextTrimming="CharacterEllipsis"
                                                    TextWrapping="NoWrap"
                                                    ToolTipService.ToolTip="Double-click to rename"
                                                    DoubleTapped="MediaPanelListName_DoubleTapped"
                                                    Visibility="{x:Bind IsNameEditMode, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert, Mode=OneWay}" />
                                                <TextBox
                                                    VerticalAlignment="Center"
                                                    MinHeight="32"
                                                    Padding="8,4"
                                                    FontSize="13"
                                                    LostFocus="MediaPanelListNameEdit_LostFocus"
                                                    KeyDown="MediaPanelListNameEdit_KeyDown"
                                                    Loaded="MediaPanelListNameEdit_Loaded"
                                                    Text="{x:Bind NameEditDraft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    Visibility="{x:Bind IsNameEditMode, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
                                            </Grid>
                                            <TextBlock
                                                Grid.Column="4"
                                                VerticalAlignment="Center"
                                                FontSize="12"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="{x:Bind Path, Mode=OneTime}"
                                                TextTrimming="CharacterEllipsis"
                                                TextWrapping="NoWrap" />
                                            <TextBlock
                                                Grid.Column="5"
                                                VerticalAlignment="Center"
                                                FontSize="12"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="{x:Bind DurationTableLabel, Mode=OneWay}"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                Grid.Column="6"
                                                VerticalAlignment="Center"
                                                FontSize="12"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="{x:Bind FormatLabel, Mode=OneWay}"
                                                TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>

                        <Border
                            Grid.Row="2"
                            Padding="0"
                            Background="{ThemeResource ShowBrowseDeckHeaderAcrylicBrush}"
                            BorderBrush="{ThemeResource ShowChromeDividerBrush}"
                            BorderThickness="0,1,0,0">
                            <Grid
                                Padding="8,5"
                                ColumnDefinitions="Auto,*,Auto"
                                ColumnSpacing="12">
                                <StackPanel
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal"
                                    Spacing="6">
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="11"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="Media"
                                        Visibility="{x:Bind ViewModel.MediaPanelOpen, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert, Mode=OneWay}" />
                                    <Border
                                        MinHeight="30"
                                        VerticalAlignment="Center"
                                        Background="{ThemeResource ControlFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4">
                                        <Grid ColumnDefinitions="*,Auto,*,Auto,*">
                                            <Button
                                                Grid.Column="0"
                                                AutomationProperties.Name="Global media cut (drawer)"
                                                Click="GlobalMediaCut_Click"
                                                CornerRadius="4,0,0,4"
                                                Style="{StaticResource ShowDeckViewModeSegmentButtonStyle}"
                                                ToolTipService.ToolTip="Cut on media change">
                                                <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                                    <Border
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Stretch"
                                                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                        CornerRadius="4,0,0,4"
                                                        Visibility="{x:Bind ViewModel.GlobalMediaTransitionIsCut, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
                                                    <Grid
                                                        Padding="10,6"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                        <TextBlock
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            FontSize="12"
                                                            Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                            Text="Cut"
                                                            Visibility="{x:Bind ViewModel.GlobalMediaTransitionIsCut, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert, Mode=OneWay}" />
                                                        <TextBlock
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            FontSize="12"
                                                            Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                                            Text="Cut"
                                                            Visibility="{x:Bind ViewModel.GlobalMediaTransitionIsCut, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
                                                    </Grid>
                                                </Grid>
                                            </Button>
                                            <Border
                                                Grid.Column="1"
                                                Width="1"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Stretch"
                                                Background="{ThemeResource CardStrokeColorDefaultBrush}" />
                                            <Button
                                                Grid.Column="2"
                                                AutomationProperties.Name="Global media dissolve (drawer)"
