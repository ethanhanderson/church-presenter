<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ChurchPresenter.Views.EditPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:ChurchPresenter.Controls"
    xmlns:converters="using:ChurchPresenter.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:models="using:ChurchPresenter.Models.Documents"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="RootPage"
    mc:Ignorable="d"
    Background="Transparent">
    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>
    <Page.KeyboardAccelerators>
        <KeyboardAccelerator Invoked="SaveKeyboardAccelerator_Invoked" Key="S" Modifiers="Control" />
        <KeyboardAccelerator Invoked="SaveAsKeyboardAccelerator_Invoked" Key="S" Modifiers="Control,Shift" />
        <KeyboardAccelerator Invoked="DuplicateKeyboardAccelerator_Invoked" Key="D" Modifiers="Control" />
        <KeyboardAccelerator Invoked="DeleteKeyboardAccelerator_Invoked" Key="Delete" />
    </Page.KeyboardAccelerators>

    <Grid ColumnDefinitions="300,*,340" Background="Transparent">
        <Grid
            Grid.Column="0"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,0,1,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Padding="16" Spacing="12">
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Edit" />
                <TextBox Header="Presentation Title" Text="{Binding PresentationTitle, Mode=TwoWay}" />
                <ComboBox
                    Header="Aspect Ratio"
                    ItemsSource="{Binding AspectRatioChoices}"
                    SelectedItem="{Binding PresentationAspectRatio, Mode=TwoWay}" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Command="{Binding AddSlideCommand}" Content="Add Slide" />
                    <Button Command="{Binding DuplicateSlideCommand}" Content="Duplicate" />
                    <Button Command="{Binding DeleteSlideCommand}" Content="Delete" />
                </StackPanel>
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{Binding CurrentPath}"
                    TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <ListView
                x:Name="SlidesList"
                Grid.Row="1"
                Margin="12,0"
                IsItemClickEnabled="True"
                ItemClick="SlidesList_ItemClick"
                ItemsSource="{Binding Slides}"
                SelectionMode="Single">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:PresentationSlide">
                        <StackPanel Margin="0,0,0,12" Spacing="6">
                            <StackPanel.ContextFlyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Click="DuplicateSlideMenuItem_Click" Text="Duplicate Slide" />
                                    <MenuFlyoutItem Click="DeleteSlideMenuItem_Click" Text="Delete Slide" />
                                    <MenuFlyoutItem Click="MoveSlideUpMenuItem_Click" Text="Move Slide Up" />
                                    <MenuFlyoutItem Click="MoveSlideDownMenuItem_Click" Text="Move Slide Down" />
                                    <MenuFlyoutItem Click="EditSlideTransitionMenuItem_Click" Text="Transitions..." />
                                </MenuFlyout>
                            </StackPanel.ContextFlyout>
                            <Border
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                                <controls:SlideStageView
                                    Height="112"
                                    Margin="8"
                                    Project="{Binding ViewModel.ProjectPreview, ElementName=RootPage}"
                                    RenderMode="Thumbnail"
                                    Slide="{Binding}" />
                            </Border>
                            <TextBlock
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{Binding SectionLabel}"
                                TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <StackPanel Grid.Row="2" Padding="16" Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Command="{Binding SaveCommand}" Content="Save Presentation" />
                    <Button Command="{Binding SaveAsCommand}" Content="Save As" />
                </StackPanel>
                <TextBlock
                    FontSize="12"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{Binding StatusMessage}"
                    TextWrapping="WrapWholeWords" />
            </StackPanel>
        </Grid>

        <Grid
            Grid.Column="1"
            Padding="16"
            Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Spacing="4">
                <TextBlock FontSize="22" FontWeight="SemiBold" Text="{Binding SelectedSlideTitle}" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{Binding PresentationAspectRatio}" />
            </StackPanel>

            <Border
                Grid.Row="1"
                Margin="0,16,0,16"
                Background="Black"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <controls:SlideStageView
                    MediaLayers="{Binding SelectedSlideMediaLayers}"
                    Margin="12"
                    Project="{Binding ProjectPreview}"
                    RenderMode="Editor"
                    ShowSafeArea="True"
                    Slide="{Binding SelectedSlidePreview}" />
            </Border>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
                <Button Command="{Binding MoveSlideUpCommand}" Content="Move Up" />
                <Button Command="{Binding MoveSlideDownCommand}" Content="Move Down" />
                <Button Command="{Binding AddTextLayerCommand}" Content="Add Text" />
                <Button Command="{Binding AddShapeLayerCommand}" Content="Add Shape" />
                <Button Command="{Binding DeleteLayerCommand}" Content="Delete Layer" />
            </StackPanel>
        </Grid>

        <ScrollViewer
            Grid.Column="2"
            Background="{ThemeResource LayerFillColorDefaultBrush}">
            <StackPanel Padding="16" Spacing="12">
                <TextBlock FontSize="22" FontWeight="SemiBold" Text="Inspector" />

                <TextBox Header="Section Label" Text="{Binding SelectedSlideSectionLabel, Mode=TwoWay}" />
                <ComboBox
                    Header="Section"
                    ItemsSource="{Binding SectionOptions}"
                    SelectedItem="{Binding SelectedSlideSection, Mode=TwoWay}" />
                <TextBox
                    Header="Notes"
                    AcceptsReturn="True"
                    MinHeight="96"
                    Text="{Binding SelectedSlideNotes, Mode=TwoWay}"
                    TextWrapping="Wrap" />

                <Border
                    Padding="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="10">
                        <TextBlock FontWeight="SemiBold" Text="Theme" />
                        <ComboBox
                            x:Name="ThemePicker"
                            Header="Theme"
                            DisplayMemberPath="Name"
                            ItemsSource="{Binding AvailableThemes}"
                            SelectedItem="{Binding SelectedThemeForSlide, Mode=OneWay}"
                            SelectionChanged="ThemePicker_SelectionChanged" />
                        <ComboBox
                            x:Name="ThemeSlidePicker"
                            Header="Slide style"
                            DisplayMemberPath="Name"
                            ItemsSource="{Binding AvailableThemeSlides}"
                            SelectedItem="{Binding SelectedThemeSlideForSlide, Mode=OneWay}"
                            SelectionChanged="ThemeSlidePicker_SelectionChanged" />
                        <ToggleSwitch Header="Updates with theme" IsOn="{Binding SelectedSlideUpdatesWithTheme, Mode=TwoWay}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button
                                Command="{Binding DetachSelectedSlideThemeCommand}"
                                Content="Customize this slide"
                                IsEnabled="{Binding HasSelectedSlide}" />
                            <Button
                                Content="Update from library"
                                IsEnabled="{Binding HasThemeUpdate}" />
                        </StackPanel>
                        <TextBlock
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{Binding ThemeUpdateMessage}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <TextBlock FontWeight="SemiBold" Text="Transition" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{Binding SelectedSlideTransitionLabel}"
                    TextWrapping="WrapWholeWords" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button
                        Click="EditSelectedSlideTransitionButton_Click"
                        Content="Edit Transition"
                        IsEnabled="{Binding HasSelectedSlide}" />
                    <Button
                        Click="ClearSelectedSlideTransitionButton_Click"
                        Content="Clear Override"
                        IsEnabled="{Binding HasSelectedSlideTransition}" />
                </StackPanel>

                <TextBlock FontWeight="SemiBold" Text="Layers" />
                <ListView
                    x:Name="LayersList"
                    Height="180"
                    IsItemClickEnabled="True"
                    ItemClick="LayersList_ItemClick"
                    ItemsSource="{Binding Layers}"
                    SelectionMode="Single">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,8">
                                <StackPanel.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Click="DeleteLayerMenuItem_Click" Text="Delete Layer" />
                                    </MenuFlyout>
                                </StackPanel.ContextFlyout>
                                <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <TextBox
                    Header="Layer Name"
                    Text="{Binding SelectedLayerName, Mode=TwoWay}"
                    Visibility="{Binding HasSelectedLayer, Converter={StaticResource BoolToVisibilityConverter}}" />

                <Grid
                    ColumnDefinitions="*,*"
                    ColumnSpacing="8"
                    Visibility="{Binding HasSelectedLayer, Converter={StaticResource BoolToVisibilityConverter}}">
                    <NumberBox Header="X" Value="{Binding SelectedLayerX, Mode=TwoWay}" />
                    <NumberBox Grid.Column="1" Header="Y" Value="{Binding SelectedLayerY, Mode=TwoWay}" />
                </Grid>

                <Grid
                    ColumnDefinitions="*,*"
                    ColumnSpacing="8"
                    Visibility="{Binding HasSelectedLayer, Converter={StaticResource BoolToVisibilityConverter}}">
                    <NumberBox Header="Width" Value="{Binding SelectedLayerWidth, Mode=TwoWay}" />
                    <NumberBox Grid.Column="1" Header="Height" Value="{Binding SelectedLayerHeight, Mode=TwoWay}" />
                </Grid>

                <Grid
                    ColumnDefinitions="*,*"
                    ColumnSpacing="8"
                    Visibility="{Binding HasSelectedLayer, Converter={StaticResource BoolToVisibilityConverter}}">
                    <NumberBox Header="Rotation" Value="{Binding SelectedLayerRotation, Mode=TwoWay}" />
                    <NumberBox Grid.Column="1" Header="Opacity" Minimum="0" Maximum="1" SmallChange="0.05" Value="{Binding SelectedLayerOpacity, Mode=TwoWay}" />
                </Grid>

                <TextBlock
                    FontWeight="SemiBold"
                    Text="Text Layer"
                    Visibility="{Binding HasSelectedTextLayer, Converter={StaticResource BoolToVisibilityConverter}}" />
                <TextBox
                    Header="Content"
                    AcceptsReturn="True"
                    MinHeight="96"
                    Text="{Binding SelectedTextContent, Mode=TwoWay}"
                    TextWrapping="Wrap"
                    Visibility="{Binding HasSelectedTextLayer, Converter={StaticResource BoolToVisibilityConverter}}" />
                <TextBox
                    Header="Font Family"
                    Text="{Binding SelectedTextFontFamily, Mode=TwoWay}"
                    Visibility="{Binding HasSelectedTextLayer, Converter={StaticResource BoolToVisibilityConverter}}" />
                <NumberBox
                    Header="Font Size"
                    Value="{Binding SelectedTextFontSize, Mode=TwoWay}"
                    Visibility="{Binding HasSelectedTextLayer, Converter={StaticResource BoolToVisibilityConverter}}" />
                <TextBox
                    Header="Text Color"
                    Text="{Binding SelectedTextColor, Mode=TwoWay}"
                    Visibility="{Binding HasSelectedTextLayer, Converter={StaticResource BoolToVisibilityConverter}}" />

                <TextBlock
                    FontWeight="SemiBold"
                    Text="Shape Layer"
                    Visibility="{Binding HasSelectedShapeLayer, Converter={StaticResource BoolToVisibilityConverter}}" />
                <ComboBox
                    Header="Shape Type"
                    ItemsSource="{Binding ShapeTypeOptions}"
                    SelectedItem="{Binding SelectedShapeType, Mode=TwoWay}"
                    Visibility="{Binding HasSelectedShapeLayer, Converter={StaticResource BoolToVisibilityConverter}}" />
                <TextBox
                    Header="Fill Color"
                    Text="{Binding SelectedShapeFillColor, Mode=TwoWay}"
                    Visibility="{Binding HasSelectedShapeLayer, Converter={StaticResource BoolToVisibilityConverter}}" />
                <TextBox
                    Header="Stroke Color"
                    Text="{Binding SelectedShapeStrokeColor, Mode=TwoWay}"
                    Visibility="{Binding HasSelectedShapeLayer, Converter={StaticResource BoolToVisibilityConverter}}" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
